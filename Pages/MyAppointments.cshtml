@page

@model SoftetroBarber.Pages.MyAppointmentsModel

@{

    ViewData["Title"] = "Randevularım";

    Layout = "_Layout";

}



<style>

    /* Masaüstü ve Genel Yapı */

    .badge-container {

        display: flex;

        justify-content: space-between;

        align-items: center;

        gap: 12px;

    }



    .badge-item {

        white-space: nowrap;

        font-weight: 700;

        letter-spacing: 0.5px;

    }



    /* MOBİLDE NOKTA ATIŞI DÜZELTME */

    @@media (max-width: 576px) {

        .dark-hero-wrapper {

            padding: 15px 10px !important;

        }



        /* Mobilde yan yana durmayı YASAKLIYORUZ. Her zaman alt alta. */

        .badge-container {

            flex-direction: column !important;

            align-items: flex-start !important;

            gap: 10px !important; /* Aralarındaki yapışmayı önleyen boşluk */

            width: 100%;

        }



        /* Rozetlerin mobilde daha okunaklı olması için genişliklerini serbest bırakıyoruz */

        .badge-item {

            display: inline-block;

            width: auto;

            font-size: 0.8rem !important;

            padding: 8px 15px !important;

        }



        .appointment-card-dark {

            padding: 20px 12px !important;

        }



        .result-card-mini {

            padding: 15px !important;

            margin-bottom: 20px !important;

        }



        /* Berber isminin rozetlerden uzaklığı */

        .barber-title {

            margin-top: 1.5rem !important;

            font-size: 1.1rem !important;

        }

    }

</style>



<div class="dark-hero-wrapper">

    <div class="d-flex flex-column align-items-center">



        <div class="top-toggle-container">

            <a asp-page="/Index" class="toggle-btn">RANDEVU AL</a>

            <a asp-page="/MyAppointments" class="toggle-btn active">RANDEVULARIM</a>

        </div>



        <div class="appointment-card-dark" style="width: 100%; max-width: 500px;">



            @if (!Model.HasSearched)

            {

                <div class="glow-icon-container">

                    <i class="bi bi-person-badge"></i>

                </div>

                <h2 class="form-title">RANDEVU SORGULA</h2>

                <p class="form-subtitle">Numaranızı girerek kayıtlarınıza ulaşın.</p>

                <form method="get" class="mt-4">

                    <div class="dark-input-group">

                        <span class="prefix">+90</span>

                        <div class="divider"></div>

                        <input type="tel" name="PhoneNumber" class="dark-input" placeholder="5XX XXX XX XX"

                               value="@Model.PhoneNumber" required />

                    </div>

                    <button type="submit" class="btn-sharp-red">SORGULAMAYI BAŞLAT</button>

                </form>

            }

            else

            {

                <div class="mt-2 w-100">

                    @if (Model.Appointments.Any())

                    {

                        foreach (var appt in Model.Appointments)

                        {

                            <div class="result-card-mini p-4 mb-3"

                                 style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; width: 100%;">

                               

                                @* Rozetler Mobilde Buradan Kontrol Ediliyor *@

                                <div class="badge-container">

                                    <span class="badge badge-softetro-red rounded-pill badge-item">

                                        @appt.StartTime.ToString("dd MMM yyyy HH:mm")

                                    </span>

                                   

                                    @switch (appt.Status)

                                    {

                                        case SoftetroBarber.Enums.AppointmentStatus.Confirmed:

                                            <span class="badge bg-success rounded-pill badge-item">Onaylandı</span>

                                            break;

                                        case SoftetroBarber.Enums.AppointmentStatus.Cancelled:

                                            <span class="badge bg-danger rounded-pill badge-item">İptal Edildi</span>

                                            break;

                                        case SoftetroBarber.Enums.AppointmentStatus.Completed:

                                            <span class="badge bg-secondary rounded-pill badge-item">Tamamlandı</span>

                                            break;

                                        case SoftetroBarber.Enums.AppointmentStatus.NoShow:

                                            <span class="badge badge-softetro-yellow rounded-pill badge-item">GELMEDİ</span>

                                            break;

                                    }

                                </div>



                                <h5 class="text-white barber-title mt-3 mb-2" style="font-weight: 700;">Berber: @appt.Barber.Name</h5>

                               

                                <div class="d-flex flex-wrap gap-2 mt-2">

                                    @foreach (var svc in appt.AppointmentServices)

                                    {

                                        <span class="badge bg-dark border border-secondary px-2 py-1" style="font-size: 0.7rem; color: #ccc;">@svc.Service.Name</span>

                                    }

                                </div>



                                <div class="d-flex justify-content-between align-items-center mt-4 pt-3"

                                     style="border-top: 1px solid rgba(255,255,255,0.1);">

                                    <span class="fw-bold"

                                          style="color: #e34c38; font-size: 1.2rem;">@appt.TotalPrice.ToString("C")</span>



                                    @if (appt.Status == SoftetroBarber.Enums.AppointmentStatus.Confirmed)

                                    {

                                        <form method="post" asp-page-handler="Cancel"

                                              onsubmit="return confirm('Randevunuzu iptal etmek istediğinize emin misiniz?');">

                                            <input type="hidden" name="appointmentId" value="@appt.Id" />

                                            <input type="hidden" name="phoneNumber" value="@Model.PhoneNumber" />

                                            <button type="submit" class="btn btn-sm btn-outline-danger"

                                                    style="border-radius: 20px; padding: 6px 16px; font-size: 0.8rem;">İptal Et</button>

                                        </form>

                                    }

                                </div>

                            </div>

                        }

                    }

                </div>

            }

        </div>

    </div>

</div> 