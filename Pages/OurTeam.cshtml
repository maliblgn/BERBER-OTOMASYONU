@page
@model SoftetroBarber.Pages.OurTeamModel
@{
    ViewData["Title"] = "Berber Kadromuz";
}

<style>
    /* Premium Premium Team UI */
    .master-wrapper {
        min-height: 75vh;
        padding: 60px 20px;
    }
    
    .section-title {
        font-weight: 900;
        font-size: 2.5rem;
        text-transform: uppercase;
        letter-spacing: 3px;
        color: #fff;
        text-shadow: 0 5px 15px rgba(227, 76, 56, 0.3);
        margin-bottom: 20px;
    }

    .section-subtitle {
        color: #888;
        font-size: 1.1rem;
        max-width: 600px;
        margin: 0 auto 50px auto;
        line-height: 1.6;
    }

    .barber-card-premium {
        background-color: #111;
        border: 1px solid #222;
        border-radius: 15px;
        overflow: hidden;
        transition: all 0.4s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .barber-card-premium:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(227, 76, 56, 0.15);
        border-color: #333;
    }

    .barber-img-wrapper {
        position: relative;
        padding-top: 100%; /* 1:1 Aspect Ratio */
        overflow: hidden;
        background-color: #080808;
    }

    .barber-img-wrapper img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: 0.5s ease;
    }

    .barber-card-premium:hover .barber-img-wrapper img {
        transform: scale(1.05);
    }

    .barber-card-body {
        padding: 30px;
        text-align: center;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .barber-name {
        font-size: 1.5rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 15px;
        letter-spacing: 1px;
    }

    .barber-bio {
        color: #777;
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 25px;
        flex-grow: 1;
    }

    .book-btn {
        background: transparent;
        border: 1px solid #e34c38;
        color: #e34c38;
        padding: 12px 25px;
        border-radius: 50px;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s;
        display: inline-block;
        letter-spacing: 1px;
        font-size: 0.85rem;
    }

    .book-btn:hover {
        background-color: #e34c38;
        color: #fff;
        box-shadow: 0 5px 15px rgba(227, 76, 56, 0.3);
    }

    /* Boş durum için */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background: #111;
        border-radius: 15px;
        border: 1px dashed #333;
    }
</style>

<div class="header-divider"></div>

<div class="master-wrapper container">
    <div class="text-center">
        <h1 class="section-title">Uzman Kadromuz</h1>
        <p class="section-subtitle">Stilinizi en iyi ellere emanet edin. Deneyimli berber kadromuz, size özel dokunuşlarla en iyi görünümü sunmak için burada.</p>
    </div>

    @if (Model.Barbers != null && Model.Barbers.Any())
    {
        <div class="row g-4 justify-content-center">
            @foreach (var barber in Model.Barbers)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="barber-card-premium">
                        <div class="barber-img-wrapper">
                            @if (!string.IsNullOrEmpty(barber.ImagePath))
                            {
                                <img src="@barber.ImagePath" alt="@barber.Name">
                            }
                            else
                            {
                                // Default placeholder if no image
                                <div class="w-100 h-100 d-flex align-items-center justify-content-center" style="position: absolute; top: 0; left: 0; background: #1a1a1a;">
                                    <i class="bi bi-person text-secondary" style="font-size: 5rem;"></i>
                                </div>
                            }
                        </div>
                        <div class="barber-card-body">
                            <h3 class="barber-name">@barber.Name</h3>
                            <p class="barber-bio">@(string.IsNullOrEmpty(barber.Bio) ? "Profesyonel saç ve sakal tasarımı uzmanı." : barber.Bio)</p>
                            <div>
                                <a href="/Booking/Step1_Services" class="book-btn">RANDEVU AL</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-people" style="font-size: 4rem; color: #444;"></i>
            <h3 class="text-light mt-3">Henüz Berber Eklenmedi</h3>
            <p class="text-muted">Yakında uzman kadromuzla hizmetinizde olacağız.</p>
        </div>
    }
</div>
