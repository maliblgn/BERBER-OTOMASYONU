@page
@model IndexModel
@{
    ViewData["Title"] = "Ana Sayfa";
}

<style>
    /* İç içe girmeyi önleyen ve kartı ferahlatan ek stiller */
    .master-booking-card {
        background-color: #1a1a1a;
        border: 1px solid #222;
        border-radius: 12px;
        width: 100%;
        max-width: 450px;
        box-shadow: 0 25px 60px rgba(0, 0, 0, 0.8);
        overflow: hidden;
    }

    .tab-header {
        display: flex;
        background-color: #111;
        border-bottom: 1px solid #222;
    }

    .tab-item {
        flex: 1;
        padding: 20px 0;
        text-align: center;
        color: #555;
        font-weight: 800;
        font-size: 0.8rem;
        letter-spacing: 1.5px;
        cursor: pointer;
        transition: 0.3s;
    }

    .tab-item.active {
        color: #fff;
        border-bottom: 2px solid #e34c38;
        background-color: rgba(227, 76, 56, 0.05);
    }

    .tab-body {
        padding: 45px 40px;
        /* İç boşluğu artırarak ferahlattık */
    }

    .content-section {
        display: flex;
        flex-direction: column;
        gap: 25px;
        /* Öğeler arasındaki o iç içe girmeyi bu çözer */
    }

    .footer-brand-text {
        display: block;
        margin-top: 30px;
        font-size: 0.7rem;
        font-weight: 800;
        color: #333;
        letter-spacing: 2px;
        text-transform: uppercase;
        border-top: 1px solid #222;
        padding-top: 20px;
    }

    /* Mavi linkleri düzelten buton sınıfları */
    .btn-pill-red {
        background-color: #e34c38 !important;
        color: #fff !important;
        padding: 16px 30px;
        border-radius: 50px;
        font-weight: 800;
        text-decoration: none;
        transition: 0.3s;
        border: none;
    }

    .btn-pill-red:hover {
        box-shadow: 0 10px 20px rgba(227, 76, 56, 0.3);
        transform: translateY(-2px);
    }

    .btn-outline-dark-custom {
        background: transparent;
        border: 1px solid #333;
        color: #888;
        padding: 16px 30px;
        border-radius: 50px;
        font-weight: 800;
        text-decoration: none;
        transition: 0.3s;
    }

    .btn-outline-dark-custom:hover {
        border-color: #e34c38;
        color: #fff;
    }
</style>

<div class="d-flex justify-content-center align-items-center" style="min-height: 85vh;">
    <div class="master-booking-card">

        <div class="tab-header">
            <div class="tab-item active" id="tab-create" onclick="switchTab('create')">RANDEVU OLUŞTUR</div>
            <div class="tab-item" id="tab-search" onclick="switchTab('search')">RANDEVULARIM</div>
        </div>

        <div class="tab-body">

            <div id="content-create" class="content-section">
                <div class="text-center mb-2">
                    <h2 class="fw-900 text-white mb-2">Hoş Geldiniz</h2>
                    <p style="color: #666; font-size: 0.9rem;">Tarzınızı yenilemek için bir adım uzağınızdayız.</p>
                </div>

                <div class="d-flex flex-column gap-3 mt-2">
                    <a href="/Booking/Step1_Services" class="btn-pill-red text-center">
                        HEMEN RANDEVU AL
                    </a>
                    <a href="#" class="btn-outline-dark-custom text-center">
                        BERBER DETAYLARI
                    </a>
                </div>

                <div class="text-center">
                    <span class="footer-brand-text">ELİT MAKAS STUDİO RANDEVU SİSTEMİ</span>
                </div>
            </div>

            <div id="content-search" class="content-section" style="display: none;">
                <div class="text-center">
                    <div class="mb-3">
                        <i class="bi bi-shield-lock"
                           style="font-size: 3.5rem; color: #e34c38; filter: drop-shadow(0 0 15px rgba(227, 76, 56, 0.3));"></i>
                    </div>
                    <h2 class="fw-bold text-white mb-2">Randevu Sorgula</h2>
                    <p style="color: #666; font-size: 0.85rem;" class="mb-4">Numaranızı girerek aktif randevularınızı
                        görüntüleyin.</p>

                        <form id="ajax-search-form">
                            <div class="dark-input-group mb-4"
                                 style="display: flex; background: #000; border: 1px solid #222; padding: 15px; border-radius: 4px; align-items: center;">
                                <span style="color: #777; font-weight: bold; margin-right: 15px;">+90</span>
                                <input type="tel" id="phoneInput" class="dark-input" placeholder="5XX XXX XX XX" required
                                       style="background: transparent; border: none; color: #fff; width: 100%; outline: none; font-weight: bold;" />
                            </div>
                            <button type="submit" id="searchBtn"
                                    class="btn-sharp-red d-flex justify-content-center align-items-center"
                                    style="width: 100%; height: 55px; border-radius: 4px; border: none; background: #e34c38; color: #fff; font-weight: 800;">
                                <span id="btnText">SORGULA</span>
                                <div id="btnSpinner" class="spinner-border spinner-border-sm text-white ms-2 d-none"
                                     role="status"></div>
                            </button>
                        </form>

                        <div id="search-results-container" class="mt-4 text-start"></div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    @section Scripts {
        <script>
                function switchTab(tabName) {
                    document.getElementById('tab-create').classList.remove('active');
                    document.getElementById('tab-search').classList.remove('active');
                    document.getElementById('tab-' + tabName).classList.add('active');

                    document.getElementById('content-create').style.display = 'none';
                    document.getElementById('content-search').style.display = 'none';

                    const activeContent = document.getElementById('content-' + tabName);
                    activeContent.style.display = 'block';
                }

                document.getElementById('ajax-search-form').addEventListener('submit', function (e) {
                    e.preventDefault();
                    const phone = document.getElementById('phoneInput').value;
                    const resultsContainer = document.getElementById('search-results-container');
                    const searchBtn = document.getElementById('searchBtn');

                    searchBtn.disabled = true;
                    resultsContainer.innerHTML = '';

                    fetch(`/MyAppointments?PhoneNumber=${phone}`)
                        .then(response => response.text())
                        .then(html => {
                            searchBtn.disabled = false;
                            let parser = new DOMParser();
                            let doc = parser.parseFromString(html, 'text/html');
                            let randevular = doc.querySelectorAll('.result-card-mini');

                            if (randevular.length > 0) {
                                randevular.forEach(r => resultsContainer.appendChild(r));
                            } else {
                                resultsContainer.innerHTML = '<p style="color: #666; text-align: center; margin-top: 20px;">Aktif randevu bulunamadı.</p>';
                            }
                        })
                        .catch(error => {
                            searchBtn.disabled = false;
                            resultsContainer.innerHTML = '<p class="text-danger text-center mt-3">Bağlantı hatası.</p>';
                        });
                });
        </script>
    }