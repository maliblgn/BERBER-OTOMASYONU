@page
@model IndexModel
@{
    ViewData["Title"] = "Ana Sayfa";
}

<style>
    /* Scoped UI for Homepage Mockup */
    .home-card {
        background-color: rgba(30, 30, 30, 0.85);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        padding: 0;
        overflow: hidden;
        backdrop-filter: blur(8px);
        margin-top: 3rem;
        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
    }

    .custom-tabs {
        display: flex;
        /* Matches the structure of the tabs in mockup */
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .custom-tab {
        flex: 1;
        text-align: center;
        padding: 24px 10px;
        font-weight: 800;
        font-size: 1.15rem;
        letter-spacing: 0.5px;
        color: var(--text-muted-dark);
        text-decoration: none;
        transition: all 0.3s;
        border-bottom: 3px solid transparent;
        background-color: rgba(0,0,0,0.2);
    }

    .custom-tab.active {
        color: var(--text-white);
        border-bottom: 3px solid var(--text-white);
        background-color: transparent;
    }
    
    .custom-tab:hover:not(.active) {
        color: var(--text-white);
        background-color: rgba(255,255,255,0.02);
    }

    .btn-hero {
        background-color: var(--theme-red);
        color: var(--text-white);
        border: none;
        border-radius: 50px; /* Fully rounded like a pill */
        padding: 16px 40px;
        font-weight: 600;
        font-size: 1.3rem;
        width: 100%;
        max-width: 500px;
        display: block;
        margin: 0 auto 20px auto;
        transition: transform 0.2s, background-color 0.2s;
        text-decoration: none;
    }

    .btn-hero:hover {
        background-color: var(--theme-red-hover);
        color: var(--text-white);
        transform: scale(1.02);
    }

    .home-footer-text {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.85rem;
        letter-spacing: 1px;
    }
</style>

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-9">
        
        <div class="home-card">
            
            <!-- Tabs Menu -->
            <div class="custom-tabs">
                <a href="#" class="custom-tab active">
                    RANDEVU OLUŞTUR
                </a>
                <a asp-page="/MyAppointments" class="custom-tab">
                    RANDEVULARIM
                </a>
            </div>

            <!-- Content Area -->
            <div class="p-5 d-flex flex-column justify-content-center" style="min-height: 400px;">
                
                <div class="text-center my-auto">
                    <!-- Red Button 1 (Link logic added) -->
                    <a asp-page="/Booking/Step1_Services" class="btn btn-hero shadow-lg">
                        HEMEN RANDEVU AL
                    </a>

                    <!-- Red Button 2 (For aesthetic display per mockup, could link to barbers info) -->
                    <a href="#" class="btn btn-hero shadow-lg mt-4">
                        BERBER DETAYLARI
                    </a>
                </div>

                <!-- Inner Card Footer -->
                <div class="text-center mt-auto pt-5">
                    <span class="home-footer-text text-uppercase">ELİT MAKAS STUDİO RANDEVU SİSTEMİ</span>
                </div>

            </div>
        </div>

    </div>
</div>
