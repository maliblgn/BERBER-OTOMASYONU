@page
@model SoftetroBarber.Pages.Booking.Step1_ServicesModel
@{
    ViewData["Title"] = "Adım 1: Hizmet Seçimi";
}

<style>
    :root {
        --theme-red: #e34c38;
        --theme-red-glow: rgba(227, 76, 56, 0.4);
    }

    /* Orijinal Siyah Panel Tasarımın */
    .dark-panel {
        background-color: #1a1a1a;
        border: 1px solid #222;
        border-radius: 12px;
        /* Köşeleri biraz daha yumuşattık */
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
    }

    .booking-card {
        background: #000;
        border: 1px solid #222;
        border-radius: 4px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .booking-card:hover {
        border-color: #444;
        background: #050505;
    }

    .booking-card.selected {
        border-color: var(--theme-red);
        background: rgba(227, 76, 56, 0.05);
    }

    /* STEP 2 İLE AYNI BUTON STİLLERİ */
    .btn-action {
        height: 55px;
        padding: 0 35px;
        font-weight: 800;
        letter-spacing: 1px;
        border-radius: 50px;
        /* Oval tasarım */
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        text-transform: uppercase;
        cursor: pointer;
    }

    .btn-sharp-red {
        background: var(--theme-red, #e34c38);
        color: #fff;
        border: none;
        padding: 0 40px;
        height: 55px;
        font-weight: 800;
        letter-spacing: 1px;
        border-radius: 4px;
        transition: 0.3s;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-sharp-red:hover {
        box-shadow: 0 5px 20px rgba(227, 76, 56, 0.4);
        filter: brightness(1.1);
    }

    /* Geri ve İleri Butonları */
    .btn-dark-outline {
        background: transparent;
        border: 1px solid #333;
        color: #888;
        padding: 0 30px;
        height: 55px;
        font-weight: 800;
        border-radius: 4px;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

    .btn-dark-outline:hover {
        border-color: var(--theme-red, #e34c38);
        color: #fff;
    }
    }

    .btn-action:active {
        transform: translateY(-1px);
    }

    /* Step Indicator ve Diğerleri */
    .step-indicator {
        display: flex;
        justify-content: space-between;
        margin: 2rem auto 4rem auto;
        position: relative;
        max-width: 600px;
    }

    .step-indicator::before {
        content: '';
        position: absolute;
        top: 15px;
        left: 0;
        width: 100%;
        height: 2px;
        background: #222;
        z-index: 1;
    }

    .step-item {
        position: relative;
        z-index: 2;
        text-align: center;
        background: #000;
        padding: 0 10px;
    }

    .step-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #111;
        color: #555;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        margin: 0 auto 8px auto;
        border: 2px solid #222;
    }

    .step-item.active .step-circle {
        background: var(--theme-red);
        color: #fff;
        border-color: var(--theme-red);
        box-shadow: 0 0 15px var(--theme-red-glow);
    }

    .price-badge {
        background: var(--theme-red);
        color: #fff;
        font-weight: 800;
        padding: 6px 12px;
        border-radius: 4px;
    }
</style>

<div class="row justify-content-center">
    <div class="col-12 text-center">
        <div class="step-indicator">
            <div class="step-item active">
                <div class="step-circle">1</div>
                <div class="step-title">Hizmet</div>
            </div>
            <div class="step-item">
                <div class="step-circle">2</div>
                <div class="step-title">Tarih</div>
            </div>
            <div class="step-item">
                <div class="step-circle">3</div>
                <div class="step-title">Saat</div>
            </div>
            <div class="step-item">
                <div class="step-circle">4</div>
                <div class="step-title">Berber</div>
            </div>
            <div class="step-item">
                <div class="step-circle">5</div>
                <div class="step-title">Onay</div>
            </div>
        </div>
    </div>
</div>

<div class="row justify-content-center pb-5">
    <div class="col-md-8 col-lg-7">
        <div class="dark-panel p-4 p-md-5">
            <div class="text-center mb-4">
                <h4 class="text-white mb-2 fw-bold">Hizmet Seçimi</h4>
                <p class="text-secondary">Almak istediğiniz hizmetleri işaretleyin.</p>
            </div>

            <form method="post">
                <div class="row g-3 mb-4">
                    @foreach (var service in Model.Services)
                    {
                        var isChecked = Model.SelectedServiceIds.Contains(service.Id);
                        <div class="col-12">
                            <label class="card booking-card h-100 p-3 @(isChecked ? "selected" : "")">
                                <div class="d-flex align-items-center">
                                    <div class="form-check fs-5 me-3 mb-0">
                                        <input class="form-check-input" type="checkbox" name="SelectedServiceIds"
                                               value="@service.Id" @(isChecked ? "checked" : "") onchange="toggleCard(this)">
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1 fw-bold text-white">@service.Name</h6>
                                        <div class="text-secondary small"><i class="bi bi-clock me-1"></i>
                                            @service.DurationInMinutes dk</div>
                                        </div>
                                        <div class="text-end">
                                            <span class="price-badge">@service.Price.ToString("C0")</span>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between mt-4 pt-4" style="border-top: 1px solid #222;">
                        <a href="/" class="btn-action btn-dark-outline">
                            <i class="bi bi-arrow-left me-2"></i> İPTAL
                        </a>
                        <button type="submit" class="btn-action btn-sharp-red">
                            İLERİ <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
                                                                        function toggleCard(checkbox) {
                                                                            const card = checkbox.closest('.booking-card');
                                                                            checkbox.checked ? card.classList.add('selected') : card.classList.remove('selected');
                                                                        }
        </script>
    }