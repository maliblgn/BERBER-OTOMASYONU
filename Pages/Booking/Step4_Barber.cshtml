@page
@model SoftetroBarber.Pages.Booking.Step4_BarberModel
@{
    ViewData["Title"] = "Adım 2: Berber Seçimi";
}

<style>
    :root {
        --theme-red: #e34c38;
        --theme-red-glow: rgba(227, 76, 56, 0.4);
    }

    /* Adım Göstergesi (Step Indicator) */
    .step-indicator {
        display: flex;
        justify-content: space-between;
        margin: 2rem auto 4rem auto;
        position: relative;
        max-width: 600px;
    }

    .step-indicator::before {
        content: '';
        position: absolute;
        top: 15px;
        left: 0;
        width: 100%;
        height: 2px;
        background: #222;
        z-index: 1;
    }

    .step-item {
        position: relative;
        z-index: 2;
        text-align: center;
        background: #000;
        padding: 0 10px;
    }

    .step-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #111;
        color: #555;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        margin: 0 auto 8px auto;
        border: 2px solid #222;
        transition: 0.3s;
    }

    .step-title {
        font-size: 0.75rem;
        color: #666;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .step-item.active .step-circle {
        background: var(--theme-red);
        color: #fff;
        border-color: var(--theme-red);
        box-shadow: 0 0 15px var(--theme-red-glow);
    }

    .step-item.active .step-title { color: #fff; }

    .step-item.completed .step-circle {
        background: rgba(227, 76, 56, 0.1);
        color: var(--theme-red);
        border-color: var(--theme-red);
    }

    /* Ana Panel Tasarımı */
    .dark-panel {
        background-color: #1a1a1a;
        border: 1px solid #222;
        border-radius: 12px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
        padding: 45px 35px;
    }

    /* --- BERBER KARTLARI --- */
    .barber-card {
        background: #000;
        border: 1px solid #222;
        border-radius: 8px;
        padding: 30px 20px; /* Sıkışmayı önleyen iç boşluk */
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .barber-card:hover {
        border-color: #444;
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .barber-avatar {
        width: 85px;
        height: 85px;
        border-radius: 50%;
        background: rgba(227, 76, 56, 0.05);
        color: var(--theme-red);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin-bottom: 20px;
        border: 1px solid rgba(227, 76, 56, 0.15);
        transition: 0.3s;
    }

    .barber-card:hover .barber-avatar {
        background: var(--theme-red);
        color: #fff;
        box-shadow: 0 0 20px var(--theme-red-glow);
    }

    /* Butonlar */
    .btn-sharp-red {
        background: var(--theme-red);
        color: #fff !important;
        border: none;
        width: 100%;
        height: 50px;
        font-weight: 800;
        letter-spacing: 1px;
        border-radius: 6px;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-transform: uppercase;
        text-decoration: none;
    }

    .btn-dark-outline {
        background: transparent;
        border: 1px solid #333;
        color: #888 !important;
        padding: 0 35px;
        height: 50px;
        font-weight: 800;
        border-radius: 6px;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        text-transform: uppercase;
    }

    /* --- MOBİL UYUMLULUK --- */
    @@media (max-width: 576px) {
        .dark-panel {
            padding: 35px 20px !important;
        }

        .step-title {
            display: none; /* Mobilde yazılar sığmazsa gizle */
        }

        .barber-card {
            padding: 25px 15px !important;
            margin-bottom: 10px;
        }

        .barber-avatar {
            width: 70px;
            height: 70px;
            font-size: 2rem;
        }

        .footer-actions {
            margin-top: 35px !important;
            padding-top: 25px !important;
            border-top: 1px solid #222;
        }
    }
</style>

<div class="container">
    @* Adım Göstergesi *@
    <div class="row justify-content-center">
        <div class="col-12 text-center">
            <div class="step-indicator">
                <div class="step-item completed">
                    <div class="step-circle"><i class="bi bi-check-lg"></i></div>
                    <div class="step-title">Hizmet</div>
                </div>
                <div class="step-item active">
                    <div class="step-circle">2</div>
                    <div class="step-title">Berber</div>
                </div>
                <div class="step-item">
                    <div class="step-circle">3</div>
                    <div class="step-title">Tarih</div>
                </div>
                <div class="step-item">
                    <div class="step-circle">4</div>
                    <div class="step-title">Onay</div>
                </div>
            </div>
        </div>
    </div>

    @* Berber Seçim Alanı *@
    <div class="row justify-content-center pb-5">
        <div class="col-md-10 col-lg-9">
            <div class="dark-panel">
                <div class="text-center mb-5">
                    <h4 class="text-white fw-bold mb-2" style="letter-spacing: 1px;">USTA SEÇİMİ</h4>
                    <p style="color: #666; font-size: 0.9rem;">Size hizmet verecek profesyoneli seçin.</p>
                </div>

                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger bg-dark text-danger border-danger mb-4" style="font-size: 0.85rem; border-radius: 10px;">
                        <div asp-validation-summary="All" class="mb-0"></div>
                    </div>
                }

                <div class="row g-4 justify-content-center">
                    @foreach (var barber in Model.AvailableBarbers)
                    {
                        <div class="col-sm-6 col-lg-4">
                            <div class="barber-card">
                                <div class="barber-avatar">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <h5 class="fw-bold text-white mb-2">@barber.Name</h5>
                                <p style="color: #666; font-size: 0.8rem; line-height: 1.6;" class="mb-4 flex-grow-1">
                                    @(string.IsNullOrEmpty(barber.Bio) ? "Profesyonel Saç Tasarımcısı" : barber.Bio)
                                </p>

                                <form method="post" class="w-100">
                                    <input type="hidden" name="barberId" value="@barber.Id" />
                                    <button type="submit" class="btn-sharp-red">
                                        SEÇ <i class="bi bi-check2-circle ms-2"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

                @* Geri Dönüş *@
                <div class="d-flex justify-content-start footer-actions mt-5">
                    <a asp-page="Step1_Services" class="btn-dark-outline">
                        <i class="bi bi-arrow-left me-2"></i> GERİ
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>