@page
@model SoftetroBarber.Pages.Booking.Step4_BarberModel
@{
    ViewData["Title"] = "Adım 4: Berber Seçimi";
}

<div class="row mb-5">
    <div class="col-12">
        <h2 class="text-center mb-4"><i class="bi bi-person-badge" style="color: var(--accent);"></i> Berber Seçimi</h2>
        
        <div class="step-indicator">
            <div class="step-item completed"><div class="step-circle"><i class="bi bi-check"></i></div><div class="step-title">Hizmetler</div></div>
            <div class="step-item completed"><div class="step-circle"><i class="bi bi-check"></i></div><div class="step-title">Tarih</div></div>
            <div class="step-item completed"><div class="step-circle"><i class="bi bi-check"></i></div><div class="step-title">Saat</div></div>
            <div class="step-item active"><div class="step-circle">4</div><div class="step-title">Berber</div></div>
            <div class="step-item"><div class="step-circle">5</div><div class="step-title">Onay</div></div>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-10">
        
        <div class="text-center mb-4">
            <h4 style="color: var(--accent);">Hizmet verebilecek müsait ustalarımız:</h4>
            <p style="color: var(--text-muted-dark);">Sadece seçtiğiniz vakit aralığında boşluğu olan berberler listelenmektedir.</p>
        </div>

        @if (!ModelState.IsValid)
        {
            <div class="alert alert-danger mx-auto" style="max-width: 600px;">
                <div asp-validation-summary="All" class="mb-0"></div>
            </div>
        }

        <div class="row g-4 justify-content-center">
            @foreach (var barber in Model.AvailableBarbers)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="card booking-card h-100 text-center text-decoration-none p-4">
                        <div class="card-body d-flex flex-column align-items-center p-0">
                            <div class="rounded-circle d-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 100px; height: 100px; font-size: 3rem; background: rgba(231,76,60,0.15); color: var(--accent);">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <h5 class="card-title fw-bold mb-1 text-white">@barber.Name</h5>
                            <p class="small mb-4 flex-grow-1" style="color: var(--text-muted-dark);">@(string.IsNullOrEmpty(barber.Bio) ? "Profesyonel Saç Tasarımcısı" : barber.Bio)</p>
                            
                            <form method="post" class="w-100 mt-auto">
                                <input type="hidden" name="barberId" value="@barber.Id" />
                                <button type="submit" class="btn w-100 rounded-pill fw-bold" style="background: var(--accent); color: #fff; border: none; padding: 10px;">
                                    Seç <i class="bi bi-check-circle ms-1"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="d-flex justify-content-between mt-5 pt-4" style="border-top: 1px solid rgba(255,255,255,0.08);">
            <a asp-page="Step3_Time" class="btn btn-outline-secondary btn-lg px-4">
                <i class="bi bi-arrow-left me-2"></i> Geri
            </a>
        </div>

    </div>
</div>
