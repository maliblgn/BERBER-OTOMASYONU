@page
@model SoftetroBarber.Pages.Booking.Step4_BarberModel
@{
    ViewData["Title"] = "Adım 4: Berber Seçimi";
}

<style>
    /* Yatay Adım Göstergesi (Step Indicator) */
    .step-indicator {
        display: flex;
        justify-content: space-between;
        margin: 2rem auto 4rem auto;
        position: relative;
        max-width: 600px;
    }

    .step-indicator::before {
        content: '';
        position: absolute;
        top: 15px;
        left: 0;
        width: 100%;
        height: 2px;
        background: #222;
        z-index: 1;
    }

    .step-item {
        position: relative;
        z-index: 2;
        text-align: center;
        background: #000;
        padding: 0 10px;
    }

    .step-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #111;
        color: #555;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        margin: 0 auto 8px auto;
        border: 2px solid #222;
        transition: 0.3s;
    }

    .step-title {
        font-size: 0.75rem;
        color: #666;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Aktif Adım */
    .step-item.active .step-circle {
        background: var(--theme-red, #e34c38);
        color: #fff;
        border-color: var(--theme-red, #e34c38);
        box-shadow: 0 0 15px rgba(227, 76, 56, 0.4);
    }

    .step-item.active .step-title {
        color: #fff;
    }

    /* Tamamlanmış Adım */
    .step-item.completed .step-circle {
        background: rgba(227, 76, 56, 0.1);
        color: var(--theme-red, #e34c38);
        border-color: var(--theme-red, #e34c38);
    }

    .step-item.completed .step-title {
        color: var(--theme-red, #e34c38);
    }

    /* Karanlık Ana Kart */
    .dark-panel {
        background-color: #1a1a1a;
        border: 1px solid #222;
        border-radius: 6px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
    }

    /* --- BERBER KARTLARI --- */
    .barber-card {
        background: #000;
        border: 1px solid #222;
        border-radius: 6px;
        padding: 25px 20px;
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .barber-card:hover {
        border-color: #444;
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    /* Berber Avatarı */
    .barber-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(227, 76, 56, 0.08);
        color: var(--theme-red, #e34c38);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        margin-bottom: 15px;
        border: 1px solid rgba(227, 76, 56, 0.2);
        transition: 0.3s;
    }

    .barber-card:hover .barber-avatar {
        background: var(--theme-red, #e34c38);
        color: #fff;
        box-shadow: 0 0 15px rgba(227, 76, 56, 0.4);
    }

    /* Geri ve Seç Butonları */
    .btn-dark-outline {
        background: transparent;
        border: 1px solid #333;
        color: #888;
        padding: 0 30px;
        height: 50px;
        font-weight: 800;
        border-radius: 4px;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

    .btn-dark-outline:hover {
        border-color: var(--theme-red, #e34c38);
        color: #fff;
    }

    .btn-sharp-red {
        background: var(--theme-red, #e34c38);
        color: #fff;
        border: none;
        width: 100%;
        height: 45px;
        font-weight: 800;
        letter-spacing: 1px;
        border-radius: 4px;
        transition: 0.3s;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-sharp-red:hover {
        box-shadow: 0 5px 20px rgba(227, 76, 56, 0.4);
        filter: brightness(1.1);
    }
</style>

<div class="row justify-content-center">
    <div class="col-12 text-center">
        <div class="step-indicator">
            <div class="step-item completed">
                <div class="step-circle"><i class="bi bi-check-lg"></i></div>
                <div class="step-title">Hizmet</div>
            </div>

            <div class="step-item active">
                <div class="step-circle">2</div>
                <div class="step-title">Berber</div>
            </div>

            <div class="step-item">
                <div class="step-circle">3</div>
                <div class="step-title">Tarih</div>
            </div>
            <div class="step-item">
                <div class="step-circle">4</div>
                <div class="step-title">Onay</div>
            </div>
        </div>
    </div>
</div>

<div class="row justify-content-center pb-5">
    <div class="col-md-10 col-lg-8">

        <div class="dark-panel p-4 p-md-5">
            <div class="text-center mb-5">
                <h4 class="text-white fw-bold mb-2">Hizmet verebilecek ustalarımız</h4>
                <p style="color: #777; font-size: 0.9rem;">Sadece seçtiğiniz vakit aralığında boşluğu olan berberler
                    listelenmektedir.</p>
                </div>

                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger mb-4"
                         style="background: rgba(227, 76, 56, 0.1); border: 1px solid #e34c38; color: #e34c38;">
                        <div asp-validation-summary="All" class="mb-0"></div>
                    </div>
                }

                <div class="row g-4 justify-content-center mb-5">
                    @foreach (var barber in Model.AvailableBarbers)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="barber-card">
                                <div class="barber-avatar">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                                <h5 class="fw-bold text-white mb-2">@barber.Name</h5>
                                <p style="color: #666; font-size: 0.85rem;" class="mb-4 flex-grow-1">
                                    @(string.IsNullOrEmpty(barber.Bio) ? "Profesyonel Saç Tasarımcısı" : barber.Bio)
                                </p>

                                <form method="post" class="w-100 mt-auto">
                                    <input type="hidden" name="barberId" value="@barber.Id" />
                                    <button type="submit" class="btn-sharp-red">
                                        SEÇ <i class="bi bi-check2-circle ms-2"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>

                <div class="d-flex justify-content-between pt-4" style="border-top: 1px solid #222;">
                    <a asp-page="Step1_Services" class="btn-dark-outline">
                        <i class="bi bi-arrow-left me-2"></i> GERİ
                    </a>
                </div>
            </div>
        </div>
    </div>