@page
@model SoftetroBarber.Pages.Booking.Step7_SuccessModel
@{
    ViewData["Title"] = "Randevunuz Alındı";
}

<style>
    /* Karanlık Ana Kart */
    .dark-panel {
        background-color: #1a1a1a;
        border: 1px solid #222;
        border-radius: 6px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
    }

    /* Başarı İkonu Parlaması (Neon Yeşil) */
    .success-glow {
        width: 110px;
        height: 110px;
        background: rgba(46, 204, 113, 0.08);
        color: #2ecc71;
        font-size: 4.5rem;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 25px;
        border: 1px solid rgba(46, 204, 113, 0.2);
        box-shadow: 0 0 30px rgba(46, 204, 113, 0.15);
        animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
    }

    /* Bilgi Kutusu */
    .info-box {
        background: #000;
        border: 1px solid #222;
        border-left: 3px solid var(--theme-red, #e34c38);
        color: #888;
        padding: 20px 25px;
        border-radius: 4px;
        text-align: left;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    /* Ana Sayfaya Dön Butonu */
    .btn-sharp-red {
        background: var(--theme-red, #e34c38);
        color: #fff;
        border: none;
        width: 100%;
        height: 55px;
        font-weight: 800;
        letter-spacing: 1px;
        border-radius: 4px;
        transition: 0.3s;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        text-transform: uppercase;
        text-decoration: none;
    }

    .btn-sharp-red:hover {
        box-shadow: 0 5px 20px rgba(227, 76, 56, 0.4);
        filter: brightness(1.1);
        color: #fff;
    }

    /* Ufak bir açılış animasyonu */
    /* Ufak bir açılış animasyonu (çift @@ ile düzeltildi) */
    @@keyframes popIn {
        0% {
            transform: scale(0.5);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    100% {
        transform: scale(1);
        opacity: 1;
    }
    }
</style>

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-8 col-lg-6">

        <div class="dark-panel p-4 p-md-5 text-center">

            <div class="success-glow">
                <i class="bi bi-check-lg"></i>
            </div>

            <h2 class="fw-bold text-white mb-3" style="letter-spacing: 1px;">Randevunuz Onaylandı!</h2>
            <p class="mb-5" style="color: #888; font-size: 1.05rem;">
                Bizi tercih ettiğiniz için teşekkür ederiz. Randevu saatinizden <strong class="text-white">10 dakika
                önce</strong> salonda olmanızı rica ederiz.
            </p>

            <div class="info-box mb-5">
                <i class="bi bi-info-circle-fill me-2" style="color: var(--theme-red, #e34c38); font-size: 1.1rem;"></i>
                Randevunuzun durumunu ve detaylarını ana sayfadaki <strong class="text-white">Randevularım</strong>
                sekmesinden telefon numaranızla dilediğiniz zaman görüntüleyebilir veya iptal edebilirsiniz.
            </div>

            <a asp-page="/Index" class="btn-sharp-red">
                <i class="bi bi-house-door me-2" style="font-size: 1.2rem;"></i> ANA SAYFAYA DÖN
            </a>

        </div>

    </div>
</div>