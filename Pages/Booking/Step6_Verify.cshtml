@page
@model SoftetroBarber.Pages.Booking.Step6_VerifyModel
@{
    ViewData["Title"] = "Adım 6: Doğrulama";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        
        <div class="card border-0 rounded-4 shadow-lg" style="background: var(--dark-card-solid);">
            <div class="card-body p-5 text-center">
                
                <div class="mb-4">
                    <i class="bi bi-whatsapp text-success" style="font-size: 4rem;"></i>
                </div>

                <h4 class="fw-bold text-white mb-3">Kodu Giriniz</h4>
                <p class="mb-4" style="color: var(--text-muted-dark);">
                    <strong class="text-white">+90 @Model.PhoneNumberMasked</strong> numarasına WhatsApp üzerinden gönderdiğimiz 6 haneli doğrulama kodunu aşağıya giriniz.
                </p>

                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger mx-auto mb-4 text-start">
                        <div asp-validation-summary="All" class="mb-0"></div>
                    </div>
                }

                <form method="post">
                    <div class="mb-4 px-3">
                        <input asp-for="OtpCode" type="text" class="form-control form-control-lg text-center fw-bold" 
                               placeholder="• • • • • •" maxlength="6" 
                               style="letter-spacing: 0.5rem; font-size: 1.5rem; background: rgba(255,255,255,0.06); border: 2px solid var(--accent); color: var(--accent);" 
                               required autofocus autocomplete="off" />
                    </div>

                    <p class="small mb-4" style="color: var(--text-muted-dark);">
                        Kod 3 dakika boyunca geçerlidir. <br> <strong style="color: var(--accent);">Test Kodu: 123456</strong>
                    </p>

                    <button type="submit" class="btn btn-success btn-lg w-100 shadow rounded-pill mb-3 fw-bold">
                        <i class="bi bi-check2-circle me-1"></i> Doğrula ve Randevuyu Onayla
                    </button>
                    
                    <a asp-page="Step5_Phone" class="btn btn-link text-decoration-none" style="color: var(--text-muted-dark);">Vazgeç ve Numaramı Düzelt</a>
                </form>
            </div>
        </div>

    </div>
</div>
