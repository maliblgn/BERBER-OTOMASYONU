@page
@model SoftetroBarber.Pages.Booking.Step5_PhoneModel
@{
    ViewData["Title"] = "Adım 5: Randevu Onayı";
}

<div class="row mb-5">
    <div class="col-12">
        <h2 class="text-center mb-4"><i class="bi bi-file-earmark-check" style="color: var(--accent);"></i> Randevu Özeti ve Onay</h2>
        
        <div class="step-indicator">
            <div class="step-item completed"><div class="step-circle"><i class="bi bi-check"></i></div><div class="step-title">Hizmetler</div></div>
            <div class="step-item completed"><div class="step-circle"><i class="bi bi-check"></i></div><div class="step-title">Tarih</div></div>
            <div class="step-item completed"><div class="step-circle"><i class="bi bi-check"></i></div><div class="step-title">Saat</div></div>
            <div class="step-item completed"><div class="step-circle"><i class="bi bi-check"></i></div><div class="step-title">Berber</div></div>
            <div class="step-item active"><div class="step-circle">5</div><div class="step-title">Onay</div></div>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 rounded-4 mb-4">
            <div class="card-header pt-4 pb-2 border-0">
                <h5 class="card-title fw-bold mb-0" style="color: var(--accent);">Randevu Detayları</h5>
            </div>
            <div class="card-body p-4">
                <div class="row mb-3 pb-3" style="border-bottom: 1px solid rgba(255,255,255,0.08);">
                    <div class="col-sm-4" style="color: var(--text-muted-dark);"><i class="bi bi-person-fill"></i> Berber</div>
                    <div class="col-sm-8 fw-bold text-white">@Model.BarberName</div>
                </div>
                <div class="row mb-3 pb-3" style="border-bottom: 1px solid rgba(255,255,255,0.08);">
                    <div class="col-sm-4" style="color: var(--text-muted-dark);"><i class="bi bi-calendar-check"></i> Tarih</div>
                    <div class="col-sm-8 fw-bold text-white">@Model.SessionData.SelectedDate.ToString("dd MMMM yyyy, dddd")</div>
                </div>
                <div class="row mb-3 pb-3" style="border-bottom: 1px solid rgba(255,255,255,0.08);">
                    <div class="col-sm-4" style="color: var(--text-muted-dark);"><i class="bi bi-clock"></i> Saat</div>
                    <div class="col-sm-8 fw-bold text-white">@Model.SessionData.SelectedTime.ToString(@"hh\:mm")</div>
                </div>
                
                <div class="mt-4">
                    <h6 class="mb-3" style="color: var(--text-muted-dark);"><i class="bi bi-list-check"></i> Seçilen Hizmetler</h6>
                    @foreach(var service in Model.SelectedServices)
                    {
                        <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom: 1px solid rgba(255,255,255,0.04);">
                            <div>
                                <span class="fw-bold text-white d-block">@service.Name</span>
                                <small style="color: var(--text-muted-dark);">@service.DurationInMinutes dk</small>
                            </div>
                            <span class="badge rounded-pill px-3 py-2" style="background: rgba(255,255,255,0.08); color: #fff;">@service.Price.ToString("C")</span>
                        </div>
                    }
                </div>
            </div>
            <div class="card-footer p-4 border-0 rounded-bottom">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fs-5" style="color: var(--text-muted-dark);">Toplam</span>
                    <h3 class="fw-bold mb-0" style="color: var(--accent);">@Model.TotalPrice.ToString("C") <small style="color: var(--text-muted-dark); font-size: 0.7em;">(@Model.TotalDuration dk)</small></h3>
                </div>
            </div>
        </div>

        @if (!ModelState.IsValid)
        {
            <div class="alert alert-danger mx-auto">
                <div asp-validation-summary="All" class="mb-0"></div>
            </div>
        }

        <div class="card border-0 rounded-4">
            <div class="card-body p-4">
                <h5 class="card-title fw-bold mb-4" style="color: var(--accent);">Kişisel Bilgileriniz</h5>
                <p class="small mb-4" style="color: var(--text-muted-dark);"><i class="bi bi-whatsapp text-success me-1"></i> Telefon numaranıza WhatsApp üzerinden bir doğrulama kodu (OTP) gönderilecektir.</p>
                
                <form method="post">
                    <div class="mb-4">
                        <label asp-for="CustomerName" class="form-label fw-bold" style="color: var(--text-muted-dark);">Ad Soyad</label>
                        <input asp-for="CustomerName" type="text" class="form-control form-control-lg" placeholder="Örn: Ahmet Yılmaz" required />
                    </div>
                    
                    <div class="mb-5">
                        <label asp-for="CustomerPhone" class="form-label fw-bold" style="color: var(--text-muted-dark);">Telefon Numarası</label>
                        <div class="input-group">
                            <span class="input-group-text">+90</span>
                            <input asp-for="CustomerPhone" type="tel" class="form-control form-control-lg" placeholder="5551234567" required pattern="[0-9]*" maxlength="11" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-page="Step4_Barber" class="btn btn-outline-secondary btn-lg px-4">
                            <i class="bi bi-arrow-left me-2"></i> Geri
                        </a>
                        <button type="submit" class="btn btn-lg px-5 shadow-sm fw-bold" style="background: var(--accent); color: #fff; border: none; border-radius: 8px;">
                            Onayla ve Kod Gönder <i class="bi bi-shield-lock ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>
