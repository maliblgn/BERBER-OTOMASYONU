@page "{handler?}"
@model SoftetroBarber.Pages.Booking.Step5_PhoneModel
@{
    ViewData["Title"] = "Randevu Onayı";
}

<style>
    :root {
        --softetro-red: #e34c38;
        --card-bg: #111;
        --border: #222;
    }

    .split-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-top: 25px;
        align-items: stretch;
    }

    /* SOL PANEL: Yeni Dikey Tasarım */
    .side-summary {
        flex: 1;
        min-width: 320px;
        background: #080808;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 35px;
        display: flex;
        flex-direction: column;
    }

    .summary-title {
        color: #555;
        font-weight: 900;
        font-size: 0.7rem;
        letter-spacing: 3px;
        margin-bottom: 30px;
        text-transform: uppercase;
        border-left: 3px solid var(--softetro-red);
        padding-left: 15px;
    }

    .info-group {
        margin-bottom: 25px;
    }

    .info-label {
        display: block;
        color: #666;
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        margin-bottom: 5px;
    }

    .info-val {
        display: block;
        color: #fff;
        font-size: 1.2rem;
        font-weight: 900;
    }

    .info-val i {
        color: var(--softetro-red);
        margin-right: 10px;
        font-size: 1.1rem;
    }

    .service-list {
        background: #0c0c0c;
        border: 1px solid #1a1a1a;
        border-radius: 8px;
        padding: 15px;
        margin-top: auto;
    }

    .service-item {
        display: flex;
        justify-content: space-between;
        border-bottom: 1px solid #151515;
        padding: 8px 0;
    }

    .service-item:last-child {
        border-bottom: none;
    }

    .total-area {
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px dashed #333;
    }

    .total-price {
        color: #fff;
        font-size: 2.2rem;
        font-weight: 900;
        line-height: 1;
    }

    /* SAĞ PANEL: Form */
    .side-form {
        flex: 1.5;
        min-width: 380px;
        background: #141414;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 40px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
    }

    .white-box-input {
        background: #fff;
        border-radius: 8px;
        display: flex;
        align-items: center;
        padding: 14px 20px;
        margin-bottom: 20px;
        border: 3px solid transparent;
        transition: 0.3s;
    }

    .white-box-input:focus-within {
        border-color: var(--softetro-red);
    }

    .inner-input {
        border: none;
        outline: none;
        width: 100%;
        font-weight: 800;
        color: #000;
        font-size: 1.1rem;
        background: transparent;
    }

    .readonly-field {
        background: #f0f0f0 !important;
        opacity: 0.7;
        pointer-events: none;
    }

    .found-tag {
        color: #2ecc71;
        font-size: 0.7rem;
        font-weight: 900;
        display: none;
        text-align: right;
        margin-bottom: 5px;
    }

    .btn-finish {
        background: var(--softetro-red);
        color: #fff;
        border: none;
        width: 100%;
        padding: 20px;
        border-radius: 8px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: 0.3s;
    }

    .btn-finish:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(227, 76, 56, 0.4);
    }
</style>

<div class="split-wrapper">
    <div class="side-summary">
        <div class="summary-title">RANDEVU BİLGİLERİ</div>

        <div class="info-group">
            <span class="info-label">SEÇİLEN BERBER</span>
            <span class="info-val"><i class="bi bi-person-badge"></i> @Model.BarberName.ToUpper()</span>
        </div>

        <div class="info-group">
            <span class="info-label">RANDEVU TARİHİ</span>
            <span class="info-val"><i class="bi bi-calendar3"></i> @Model.SessionData.SelectedDate.ToString("dd MMMM              yyyy")</span>
        </div>

        <div class="info-group">
            <span class="info-label">SAAT</span>
            <span class="info-val text-danger"><i class="bi bi-clock-fill"></i>
                @Model.SessionData.SelectedTime.ToString(@"hh\:mm")</span>
            </div>

            <div class="service-list">
                <span class="info-label" style="margin-bottom: 10px;">HİZMETLER</span>
                @foreach (var s in Model.SelectedServices)
                {
                    <div class="service-item">
                        <span class="text-secondary small">@s.Name</span>
                        <span class="text-white fw-bold small">@s.Price.ToString("C0")</span>
                    </div>
                }
            </div>

            <div class="total-area">
                <span class="info-label">TOPLAM ÖDEME</span>
                <div class="d-flex justify-content-between align-items-end">
                    <span class="total-price">@Model.TotalPrice.ToString("C0")</span>
                    <span class="text-muted fw-bold small">@Model.TotalDuration DK</span>
                </div>
            </div>
        </div>

        <div class="side-form">
            <form method="post">
                <h5 class="text-white fw-900 mb-4">MÜŞTERİ BİLGİSİ</h5>

                @if (!ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 small bg-transparent border-danger text-danger mb-4">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <label class="text-secondary fw-bold small mb-2">TELEFON NUMARASI</label>
                <div class="white-box-input">
                    <span class="fw-bold me-2 text-dark">+90</span>
                    <input asp-for="CustomerPhone" type="tel" id="phoneInput" class="inner-input"
                           placeholder="5XX XXX XX XX" maxlength="10" required />
                </div>

                <div id="foundTag" class="found-tag"><i class="bi bi-person-check-fill"></i> SİZİ HATIRLADIK!</div>
                <label class="text-secondary fw-bold small mb-2">ADINIZ VE SOYADINIZ</label>
                <div class="white-box-input" id="nameWrapper">
                    <input asp-for="CustomerName" type="text" id="nameInput" class="inner-input"
                           placeholder="Ad-Soyad girin..." required />
                </div>

                <button type="submit" class="btn-finish">
                    ONAY KODU GÖNDER <i class="bi bi-whatsapp ms-2"></i>
                </button>

                <a asp-page="Step2_Date" class="btn d-block text-center mt-3 text-secondary small fw-bold">
                    <i class="bi bi-arrow-left me-1"></i> Tarih Seçimine Dön
                </a>
            </form>
        </div>
    </div>

    <script>
        const pInput = document.getElementById('phoneInput');
        const nInput = document.getElementById('nameInput');
        const nWrapper = document.getElementById('nameWrapper');
        const fTag = document.getElementById('foundTag');

        pInput.addEventListener('input', async function () {
            this.value = this.value.replace(/[^0-9]/g, '');

            if (this.value.length === 10) {
                const res = await fetch(`?handler=CheckCustomer&phone=${this.value}`);
                const data = await res.json();

                if (data.found) {
                    nInput.value = data.name;
                    nInput.readOnly = true;
                    nWrapper.classList.add('readonly-field');
                    fTag.style.display = 'block';
                    nWrapper.style.borderColor = '#2ecc71';
                } else {
                    clearName();
                }
            } else if (this.value.length < 10) {
                clearName();
            }
        });

        function clearName() {
            nInput.value = "";
            nInput.readOnly = false;
            nWrapper.classList.remove('readonly-field');
            fTag.style.display = 'none';
            nWrapper.style.borderColor = 'transparent';
        }
    </script>