@page
@model SoftetroBarber.Pages.Booking.Step5_PhoneModel
@{
    ViewData["Title"] = "Adım 5: Randevu Onayı";
}

<style>
    :root {
        --theme-red: #e34c38;
        --theme-red-glow: rgba(227, 76, 56, 0.4);
    }

    /* Yatay Adım Göstergesi */
    .step-indicator {
        display: flex;
        justify-content: space-between;
        margin: 2rem auto 4rem auto;
        position: relative;
        max-width: 600px;
    }

    .step-indicator::before {
        content: '';
        position: absolute;
        top: 15px;
        left: 0;
        width: 100%;
        height: 2px;
        background: #222;
        z-index: 1;
    }

    .step-item {
        position: relative;
        z-index: 2;
        text-align: center;
        background: #000;
        padding: 0 10px;
    }

    .step-circle {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #111;
        color: #555;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        margin: 0 auto 8px auto;
        border: 2px solid #222;
    }

    .step-item.active .step-circle {
        background: var(--theme-red);
        color: #fff;
        border-color: var(--theme-red);
        box-shadow: 0 0 15px var(--theme-red-glow);
    }

    .step-item.completed .step-circle {
        background: rgba(227, 76, 56, 0.1);
        color: var(--theme-red);
        border-color: var(--theme-red);
    }

    /* Karanlık Ana Kartlar */
    .dark-panel {
        background-color: #1a1a1a;
        border: 1px solid #222;
        border-radius: 8px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
    }

    /* BEYAZ INPUT GRUBU (8px Radius) */
    .white-input-group {
        display: flex;
        align-items: center;
        background: #fff;
        border: 2px solid #fff;
        padding: 0 15px;
        height: 60px;
        border-radius: 8px;
        /* İstediğin gibi azaltıldı */
        transition: all 0.3s ease;
    }

    .white-input-group:focus-within {
        border-color: var(--theme-red);
        box-shadow: 0 0 15px rgba(227, 76, 56, 0.3);
    }

    /* Input İç Stili */
    .white-input {
        background: transparent;
        border: none;
        color: #333;
        width: 100%;
        outline: none;
        font-weight: bold;
        font-size: 1.1rem;
    }

    .prefix {
        color: #333;
        font-weight: bold;
        font-size: 1.1rem;
    }

    .divider {
        width: 1px;
        height: 25px;
        background: #ddd;
        margin: 0 15px;
    }

    /* BUTONLAR (Zıplayan Efekt) */
    .btn-sharp-red {
        background: var(--theme-red);
        color: #fff;
        border: none;
        height: 60px;
        font-weight: 800;
        letter-spacing: 1px;
        border-radius: 8px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-transform: uppercase;
    }

    .btn-sharp-red:hover {
        box-shadow: 0 10px 25px var(--theme-red-glow);
        transform: translateY(-5px);
        color: #fff;
    }

    .btn-dark-outline {
        background: transparent;
        border: 1px solid #333;
        color: #888;
        height: 60px;
        font-weight: 800;
        border-radius: 8px;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

    .btn-dark-outline:hover {
        border-color: #555;
        transform: translateY(-5px);
        color: #fff;
    }

    /* Chrome Autofill Fix */
    input:-webkit-autofill {
        -webkit-box-shadow: 0 0 0 30px #fff inset !important;
        -webkit-text-fill-color: #333 !important;
    }
</style>

<div class="row justify-content-center">
    <div class="col-12 text-center">
        <div class="step-indicator">
            <div class="step-item completed">
                <div class="step-circle"><i class="bi bi-check-lg"></i></div>
                <div class="step-title">Hizmet</div>
            </div>
            <div class="step-item completed">
                <div class="step-circle"><i class="bi bi-check-lg"></i></div>
                <div class="step-title">Tarih</div>
            </div>
            <div class="step-item completed">
                <div class="step-circle"><i class="bi bi-check-lg"></i></div>
                <div class="step-title">Saat</div>
            </div>
            <div class="step-item completed">
                <div class="step-circle"><i class="bi bi-check-lg"></i></div>
                <div class="step-title">Berber</div>
            </div>
            <div class="step-item active">
                <div class="step-circle">5</div>
                <div class="step-title">Onay</div>
            </div>
        </div>
    </div>
</div>

<div class="row justify-content-center pb-5">
    <div class="col-md-10 col-lg-8">

        <div class="dark-panel mb-4">
            <div class="p-4 p-md-5" style="border-bottom: 1px solid #222;">
                <h5 class="fw-bold text-white mb-4"><i class="bi bi-file-earmark-check me-2"
                                                           style="color: var(--theme-red, #e34c38);"></i> Randevu Özeti</h5>

                    <div class="row mb-3 pb-3" style="border-bottom: 1px solid #222;">
                        <div class="col-sm-4" style="color: #777;"><i class="bi bi-person-fill me-2"></i> Berber</div>
                        <div class="col-sm-8 fw-bold text-white">@Model.BarberName</div>
                    </div>
                    <div class="row mb-3 pb-3" style="border-bottom: 1px solid #222;">
                        <div class="col-sm-4" style="color: #777;"><i class="bi bi-calendar-check me-2"></i> Tarih</div>
                        <div class="col-sm-8 fw-bold text-white">@Model.SessionData.SelectedDate.ToString("dd MMMM yyyy,                      dddd")</div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-sm-4" style="color: #777;"><i class="bi bi-clock me-2"></i> Saat</div>
                        <div class="col-sm-8 fw-bold text-white">@Model.SessionData.SelectedTime.ToString(@"hh\:mm")</div>
                    </div>

                    <h6 class="mb-3 mt-4 text-white fw-bold"><i class="bi bi-list-check me-2"
                                                                    style="color: var(--theme-red, #e34c38);"></i> Seçilen Hizmetler</h6>
                        <div class="p-3" style="background: #000; border: 1px solid #222; border-radius: 4px;">
                            @foreach (var service in Model.SelectedServices)
                            {
                                <div class="d-flex justify-content-between align-items-center py-2"
                                     style="border-bottom: 1px solid #111;">
                                    <div>
                                        <span class="fw-bold text-white d-block">@service.Name</span>
                                        <small style="color: #666;">@service.DurationInMinutes dk</small>
                                    </div>
                                    <span
                                    style="color: var(--theme-red, #e34c38); font-weight: 800;">@service.Price.ToString("C0")</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="p-4 d-flex justify-content-between align-items-center" style="background: rgba(0,0,0,0.3);">
                        <span class="fs-6"
                              style="color: #888; text-transform: uppercase; font-weight: 800; letter-spacing: 1px;">Toplam</span>
                        <h3 class="fw-bold mb-0 text-white">
                            @Model.TotalPrice.ToString("C0")
                            <small
                                style="color: #666; font-size: 0.5em; display: block; text-align: right;">(@Model.TotalDuration
                                dk)</small>
                            </h3>
                        </div>
                    </div>

                    @if (!ModelState.IsValid)
                    {
                        <div class="alert alert-danger mb-4"
                             style="background: rgba(227, 76, 56, 0.1); border: 1px solid #e34c38; color: #e34c38;">
                            <div asp-validation-summary="All" class="mb-0"></div>
                        </div>
                    }

                    <div class="dark-panel p-4 p-md-5">
                        <h5 class="fw-bold text-white mb-2">Kişisel Bilgileriniz</h5>
                        <p class="mb-4" style="color: #888; font-size: 0.85rem;">
                            <i class="bi bi-whatsapp me-1" style="color: #25D366; font-size: 1rem;"></i>
                            Telefon numaranıza WhatsApp üzerinden bir <strong class="text-white">doğrulama kodu (OTP)</strong>
                            gönderilecektir.
                        </p>

                        <form method="post">
                            <div class="mb-4">
                                <label asp-for="CustomerName" class="form-label text-white fw-bold mb-2"
                                       style="font-size: 0.9rem; letter-spacing: 0.5px;">AD SOYAD</label>
                                <div class="mb-4">
                                    <label asp-for="CustomerName" class="form-label text-white fw-bold small mb-2 ms-1">ADINIZ
                                        SOYADINIZ</label>
                                        <div class="white-input-group">
                                            <input asp-for="CustomerName" type="text" class="white-input"
                                                   placeholder="Örn: Ahmet Yılmaz" required autocomplete="off" />
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-5">
                                    <label class="form-label text-white fw-bold small mb-2 ms-1">TELEFON NUMARASI</label>
                                    <div class="white-input-group">
                                        <span class="prefix">+90</span>
                                        <div class="divider"></div>
                                        <input asp-for="CustomerPhone" type="tel" id="phoneInput" class="white-input"
                                               placeholder="5XX XXX XX XX" required maxlength="10"
                                               oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
                                    </div>
                                </div>

                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center pt-4 mt-2"
                                     style="border-top: 1px solid #222; gap: 15px;">
                                    <a asp-page="Step4_Barber" class="btn-dark-outline w-100 w-md-auto">
                                        <i class="bi bi-arrow-left me-2"></i> GERİ
                                    </a>
                                    <button type="submit" class="btn-sharp-red w-100 w-md-auto">
                                        ONAYLA VE KOD GÖNDER <i class="bi bi-shield-lock ms-2"></i>
                                    </button>
                                </div>
                            </form>
                        </div>

                    </div>
                </div>