@page
@model SoftetroBarber.Pages.Booking.Step2_DateTimeModel
@{
    ViewData["Title"] = "Adım 2: Zaman Seçimi";
}

<style>
    /* SOFTETRO STEP INDICATOR */
    .step-indicator {
        display: flex;
        justify-content: space-between;
        margin: 2rem auto 3.5rem auto;
        position: relative;
        max-width: 550px;
    }

    .step-indicator::before {
        content: '';
        position: absolute;
        top: 16px;
        left: 0;
        width: 100%;
        height: 2px;
        background: #222;
        z-index: 1;
    }

    .step-item {
        position: relative;
        z-index: 2;
        text-align: center;
        background: #000;
        padding: 0 12px;
    }

    .step-circle {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #111;
        color: #555;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
        margin: 0 auto 8px auto;
        border: 2px solid #222;
        transition: 0.4s;
    }

    .step-item.active .step-circle {
        background: #e34c38;
        color: #fff;
        border-color: #e34c38;
        box-shadow: 0 0 15px rgba(227, 76, 56, 0.5);
    }

    .step-item.completed .step-circle {
        background: rgba(227, 76, 56, 0.15);
        color: #e34c38;
        border-color: #e34c38;
    }

    /* DARK PANEL VE INPUT */
    .dark-panel {
        background-color: #161616;
        border: 1px solid #252525;
        border-radius: 12px;
        box-shadow: 0 25px 60px rgba(0, 0, 0, 0.8);
    }

    .dark-date-input {
        background: #000;
        border: 2px solid #e34c38;
        color: #fff;
        padding: 14px 25px;
        border-radius: 50px;
        font-size: 1.2rem;
        font-weight: 800;
        text-align: center;
        outline: none;
        color-scheme: dark;
        transition: 0.3s;
        cursor: pointer;
    }

    /* SAAT GRİDİ */
    .time-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(95px, 1fr));
        gap: 12px;
    }

    .time-slot-btn {
        height: 50px;
        border-radius: 8px;
        font-weight: 800;
        font-size: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
        border: 1px solid #333;
        background: #080808;
        color: #fff;
        width: 100%;
        cursor: pointer;
    }

    .time-slot-btn.available:hover {
        border-color: #e34c38;
        background: rgba(227, 76, 56, 0.1);
        color: #e34c38;
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.5);
    }

    .time-slot-btn.booked {
        opacity: 0.15;
        cursor: not-allowed;
        text-decoration: line-through;
        border-color: #111;
    }

    .btn-soft-outline {
        background: transparent;
        border: 1px solid #333;
        color: #777;
        padding: 12px 35px;
        font-weight: 800;
        border-radius: 8px;
        text-decoration: none;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
    }

    .btn-soft-outline:hover {
        color: #fff;
        border-color: #fff;
    }

    .btn-dark-outline {
        background: transparent;
        border: 1px solid #333;
        color: #888;
        padding: 0 30px;
        height: 50px;
        font-weight: 800;
        border-radius: 4px;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

    .btn-dark-outline:hover {
        border-color: var(--theme-red, #e34c38);
        color: #fff;
    }
</style>

<div class="row justify-content-center">
    <div class="col-12 text-center">
        <div class="step-indicator">
            <div class="step-item completed">
                <div class="step-circle"><i class="bi bi-check-lg"></i></div>
                <div class="step-title">Hizmet</div>
            </div>

            <div class="step-item completed">
                <div class="step-circle"><i class="bi bi-check-lg"></i></div>
                <div class="step-title">Berber</div>
            </div>

            <div class="step-item active">
                <div class="step-circle">3</div>
                <div class="step-title">Tarih</div>
            </div>

            <div class="step-item">
                <div class="step-circle">4</div>
                <div class="step-title">Onay</div>
            </div>
        </div>
    </div>
</div>

<div class="row justify-content-center pb-5">
    <div class="col-md-10 col-lg-8">
        <div class="dark-panel p-4 p-md-5">

            <div class="text-center mb-5">
                <h4 class="text-white fw-900 mb-4 text-uppercase" style="letter-spacing: 1px;">Randevu Tarihi</h4>
                <form id="dateForm" method="get">
                    @* Name: SelectedDate olması kritik (Model ile eşleşme) *@
                    <input type="date" name="SelectedDate" class="dark-date-input"
                           value="@Model.SelectedDate.ToString("yyyy-MM-dd")" min="@DateTime.Today.ToString("yyyy-MM-dd")"
                           max="@DateTime.Today.AddDays(14).ToString("yyyy-MM-dd")" onchange="this.form.submit()" />
                </form>
            </div>

            <hr style="border-color: #222; border-style: dashed;" class="my-5">

            <div class="text-center mb-4">
                <h6 class="text-danger fw-900 text-uppercase small" style="letter-spacing: 3px;">
                    <i class="bi bi-calendar-event me-2"></i> @Model.SelectedDate.ToString("dd MMMM yyyy,                  dddd").ToUpper()
                </h6>
            </div>

            @if (Model.TimeSlots != null && Model.TimeSlots.Any())
            {
                <div class="time-grid">
                    @foreach (var slot in Model.TimeSlots)
                    {
                        if (slot.IsBooked)
                        {
                            <button type="button" class="time-slot-btn booked" disabled>@slot.Time.ToString(@"hh\:mm")</button>
                        }
                        else
                        {
                            <form method="post" class="m-0">
                                <input type="hidden" name="selectedTime" value="@slot.Time" />
                                <input type="hidden" name="SelectedDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                                <button type="submit" class="time-slot-btn available">@slot.Time.ToString(@"hh\:mm")</button>
                            </form>
                        }
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-clock-history d-block mb-3 text-muted" style="font-size: 3rem;"></i>
                    <p class="text-secondary fw-bold">Seçilen tarihte uygun saat dilimi bulunamadı.</p>
                </div>
            }
            <div class="d-flex justify-content-between pt-4 mt-5" style="border-top: 1px solid #222;">
                <a asp-page="/Booking/Step4_Barber" class="btn-dark-outline">
                    <i class="bi bi-arrow-left me-2"></i> Geri
                </a>
            </div>
        </div>
    </div>
</div>