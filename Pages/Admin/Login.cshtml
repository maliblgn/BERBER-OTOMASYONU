@page
@model SoftetroBarber.Pages.Admin.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Yetkili Girişi";
}

<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Berber Girişi - Softetro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
            :root {
                --theme-red: #e34c38;
                --theme-red-glow: rgba(227, 76, 56, 0.4);
            }

            body {
                background-color: #000;
                background-image:
                    radial-gradient(circle at 20% 30%, rgba(227, 76, 56, 0.05) 0%, transparent 50%),
                    radial-gradient(circle at 80% 70%, rgba(227, 76, 56, 0.05) 0%, transparent 50%);
                min-height: 100vh;
                /* Klavye açılınca bozulmaması için */
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0;
                font-family: 'Inter', sans-serif;
                padding: 20px;
            }

            .login-card {
                background: #111;
                border: 1px solid #222;
                border-radius: 16px;
                box-shadow: 0 30px 70px rgba(0, 0, 0, 1);
                width: 100%;
                max-width: 420px;
                padding: 45px;
                position: relative;
                animation: fadeIn 0.8s ease;
            }

            @@keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .brand-icon-container {
                width: 80px;
                height: 80px;
                background: #000;
                border: 1px solid #222;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 30px auto;
                color: #ffffff;
                font-size: 2.2rem;
                filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.05));
            }

            .login-title {
                color: #fff;
                font-weight: 900;
                letter-spacing: 1px;
                text-transform: uppercase;
                font-size: 1.6rem;
                margin-bottom: 5px;
            }

            .login-subtitle {
                color: #555;
                font-size: 0.8rem;
                font-weight: 800;
                letter-spacing: 2px;
                margin-bottom: 35px;
                text-transform: uppercase;
            }

            .dark-label {
                color: #888;
                font-weight: 800;
                font-size: 0.7rem;
                letter-spacing: 1.5px;
                margin-bottom: 10px;
                display: block;
            }

            /* Beyaz Input Grubu */
            .light-input-group {
                display: flex;
                align-items: center;
                background: #fff;
                border: 1px solid #ddd;
                border-radius: 8px;
                padding: 0 20px;
                margin-bottom: 25px;
                height: 60px;
                transition: 0.3s;
            }

            .light-input-group:focus-within {
                border-color: var(--theme-red);
                box-shadow: 0 0 15px rgba(227, 76, 56, 0.2);
            }

            .light-input-group i {
                color: var(--theme-red);
                font-size: 1.2rem;
                margin-right: 15px;
            }

            .light-input {
                background: transparent;
                border: none;
                color: #111;
                width: 100%;
                outline: none;
                font-weight: 800;
                font-size: 1rem;
            }

            .light-input::placeholder {
                color: #ccc;
                font-weight: 600;
            }

            .btn-sharp-red {
                background: var(--theme-red);
                color: #fff !important;
                border: none;
                width: 100%;
                height: 60px;
                font-weight: 900;
                letter-spacing: 1.5px;
                border-radius: 50px;
                transition: all 0.3s ease;
                cursor: pointer;
                text-transform: uppercase;
                margin-top: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                text-decoration: none;
            }

            .btn-sharp-red:hover {
                box-shadow: 0 10px 25px rgba(227, 76, 56, 0.4);
                transform: translateY(-2px);
            }

            .back-link {
                color: #444;
                text-decoration: none;
                font-size: 0.75rem;
                font-weight: 800;
                margin-top: 25px;
                display: inline-block;
                transition: 0.3s;
                text-transform: uppercase;
                letter-spacing: 1px;
            }

            .back-link:hover {
                color: #fff;
            }

            /* --- MOBİL AYARLAR --- */
            @@media (max-width: 576px) {
                .login-card {
                    padding: 35px 25px !important;
                }

                .login-title {
                    font-size: 1.35rem;
                }

                .brand-icon-container {
                    width: 70px;
                    height: 70px;
                    font-size: 1.8rem;
                    margin-bottom: 25px;
                }

                .light-input-group {
                    height: 55px;
                    padding: 0 15px;
                }

                .btn-sharp-red {
                    height: 55px;
                    font-size: 0.85rem;
                }
            }
    </style>
</head>

<body>

    <div class="login-card text-center">
        <div class="brand-icon-container">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <h4 class="login-title">BERBER GİRİŞİ</h4>
        <p class="login-subtitle">SOFTETRO YÖNETİM</p>

        <form method="post">
            <div class="text-start">
                <label class="dark-label">KULLANICI ADI</label>
                <div class="light-input-group">
                    <i class="bi bi-person-fill"></i>
                    <input asp-for="Username" type="text" class="light-input" placeholder="Kullanıcı adınız" required
                           autofocus autocomplete="username" />
                </div>
            </div>

            <div class="text-start">
                <label class="dark-label">GÜVENLİ ŞİFRE</label>
                <div class="light-input-group">
                    <i class="bi bi-key-fill"></i>
                    <input asp-for="Password" type="password" class="light-input" placeholder="••••••" required
                           autocomplete="current-password" />
                </div>
            </div>

            <button type="submit" class="btn-sharp-red shadow-lg">
                SİSTEME GİRİŞ YAP <i class="bi bi-arrow-right-short ms-1" style="font-size: 1.5rem;"></i>
            </button>

            <div>
                <a href="/" class="back-link">
                    <i class="bi bi-arrow-left me-1"></i> ANA SAYFAYA DÖN
                </a>
            </div>
        </form>
    </div>

</body>

</html>