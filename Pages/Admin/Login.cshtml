@page
@model SoftetroBarber.Pages.Admin.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Yetkili Girişi";
}

<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Berber Girişi - Softetro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
                        :root {
                            --theme-red: #e34c38;
                            --theme-red-glow: rgba(227, 76, 56, 0.4);
                        }

                        body {
                            background-color: #000;
                            background-image:
                                radial-gradient(circle at 20% 30%, rgba(227, 76, 56, 0.05) 0%, transparent 50%),
                                radial-gradient(circle at 80% 70%, rgba(227, 76, 56, 0.05) 0%, transparent 50%);
                            height: 100vh;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            margin: 0;
                            font-family: 'Inter', sans-serif;
                        }

                        .login-card {
                            background: #111;
                            /* Biraz daha koyu, kart belirginleşsin */
                            border: 1px solid #222;
                            border-radius: 12px;
                            box-shadow: 0 30px 70px rgba(0, 0, 0, 1);
                            width: 100%;
                            max-width: 420px;
                            padding: 45px;
                            position: relative;
                        }

                        /* İkon Beyaz Oldu */
                        .brand-icon-container {
                            width: 80px;
                            height: 80px;
                            background: #000;
                            border: 1px solid #222;
                            border-radius: 50%;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            margin: 0 auto 30px auto;
                            color: #ffffff;
                            /* Beyaz ikon */
                            font-size: 2.5rem;
                            filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.1));
                        }

                        .login-title {
                            color: #fff;
                            font-weight: 900;
                            letter-spacing: 1px;
                            text-transform: uppercase;
                            font-size: 1.6rem;
                            margin-bottom: 5px;
                        }

                        .login-subtitle {
                            color: #666;
                            font-size: 0.85rem;
                            font-weight: 700;
                            letter-spacing: 1px;
                            margin-bottom: 35px;
                        }

                        /* Beyaz Input Stilleri */
                        .dark-label {
                            color: #aaa;
                            font-weight: 800;
                            font-size: 0.75rem;
                            letter-spacing: 1px;
                            margin-bottom: 10px;
                            display: block;
                        }

                        .light-input-group {
                            display: flex;
                            align-items: center;
                            background: #fff;
                            /* Arka plan beyaz */
                            border: 1px solid #ddd;
                            border-radius: 8px;
                            padding: 0 20px;
                            margin-bottom: 25px;
                            height: 60px;
                            transition: 0.3s;
                        }

                        .light-input-group i {
                            color: #e34c38;
                            /* İkonlar kırmızı kalsın, dikkat çeksin */
                            font-size: 1.3rem;
                            margin-right: 15px;
                        }

                        .light-input {
                            background: transparent;
                            border: none;
                            color: #111;
                            /* Yazı siyah */
                            width: 100%;
                            outline: none;
                            font-weight: 800;
                            /* Kalın font */
                            font-size: 1.05rem;
                        }

                        .light-input::placeholder {
                            color: #bbb;
                            font-weight: 600;
                        }

                        /* Buton Efekti */
                        .btn-sharp-red {
                            background: var(--theme-red);
                            color: #fff;
                            border: none;
                            width: 100%;
                            height: 60px;
                            font-weight: 900;
                            letter-spacing: 1.5px;
                            border-radius: 50px;
                            /* Diğer butonların gibi oval */
                            transition: all 0.3s ease;
                            cursor: pointer;
                            text-transform: uppercase;
                            margin-top: 10px;
                        }

                        .btn-sharp-red:hover {
                            box-shadow: 0 10px 25px rgba(227, 76, 56, 0.4);
                            transform: translateY(-2px);
                        }

                        .back-link {
                            color: #555;
                            text-decoration: none;
                            font-size: 0.85rem;
                            font-weight: 800;
                            margin-top: 20px;
                            display: inline-block;
                            transition: 0.3s;
                        }

                        .back-link:hover {
                            color: #fff;
                        }
    </style>
</head>

<body>

    <div class="login-card text-center">
        <div class="brand-icon-container">
            <i class="bi bi-key-fill"></i>
        </div>

        <h4 class="login-title">BERBER GİRİŞİ</h4>
        <p class="login-subtitle">ELİT MAKAS YÖNETİM SİSTEMİ</p>

        <form method="post">
            <div class="text-start">
                <label class="dark-label">KULLANICI ADI</label>
                <div class="light-input-group">
                    <i class="bi bi-person-fill"></i>
                    <input asp-for="Username" type="text" class="light-input" placeholder="Kullanıcı adınız" required
                           autofocus />
                </div>
            </div>

            <div class="text-start">
                <label class="dark-label">GÜVENLİ ŞİFRE</label>
                <div class="light-input-group">
                    <i class="bi bi-key-fill"></i>
                    <input asp-for="Password" type="password" class="light-input" placeholder="••••••" required />
                </div>
            </div>

            <button type="submit" class="btn-sharp-red shadow-lg">
                SİSTEME GİRİŞ YAP
            </button>

            <div>
                <a href="/" class="back-link">
                    <i class="bi bi-arrow-left me-1"></i> ANA SAYFAYA DÖN
                </a>
            </div>
        </form>
    </div>

</body>

</html>