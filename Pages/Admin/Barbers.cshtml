@page
@model SoftetroBarber.Pages.Admin.BarbersModel
@{
    ViewData["Title"] = "Berber Yönetimi";
}

<style>
    /* SOFTETRO PREMIUM UI */
    body {
        background-color: #0c0c0c;
        color: #fff;
    }

    .admin-card {
        background-color: #1a1a1a;
        border: 1px solid #222;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        overflow: hidden;
    }

    .admin-card-header {
        background-color: #111;
        border-bottom: 1px solid #222;
        padding: 18px 25px;
    }

    /* Giriş Alanları */
    .dark-input,
    .dark-textarea {
        background-color: #000;
        border: 1px solid #222;
        color: #fff;
        border-radius: 8px;
        padding: 12px 15px;
        width: 100%;
        outline: none;
        transition: 0.3s;
    }

    .dark-input:focus {
        border-color: #e34c38;
    }

    .btn-sharp-red {
        background: #e34c38;
        color: #fff;
        border: none;
        width: 100%;
        height: 50px;
        font-weight: 800;
        border-radius: 8px;
        transition: 0.3s;
        cursor: pointer;
    }

    /* Tablo Tasarımı */
    .dark-table {
        color: #ccc;
        margin-bottom: 0;
    }

    .dark-table thead th {
        background-color: #0a0a0a;
        color: #888;
        font-weight: 900;
        text-transform: uppercase;
        font-size: 0.65rem;
        padding: 15px 20px;
    }

    .dark-table tbody td {
        border-bottom: 1px solid #222;
        padding: 12px 20px;
        vertical-align: middle;
    }

    /* BUTONLAR */
    .btn-action-soft {
        background: transparent;
        border: 1px solid #333;
        color: #888;
        padding: 6px 12px;
        font-size: 0.7rem;
        font-weight: 800;
        border-radius: 5px;
        transition: 0.2s;
        cursor: pointer;
    }

    .btn-action-soft:hover {
        border-color: #fff;
        color: #fff;
        background: rgba(255, 255, 255, 0.05);
    }

    .btn-delete:hover {
        background: #e34c38;
        border-color: #e34c38;
        color: #fff;
    }

    /* SOFTETRO MODAL */
    #softetroModal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.85);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        backdrop-filter: blur(5px);
    }

    .modal-box {
        background: #1a1a1a;
        border-radius: 15px;
        padding: 30px;
        width: 380px;
        text-align: center;
        border-top: 4px solid #e34c38;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
    }
</style>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="admin-card">
            <div class="admin-card-header">
                <h6 class="fw-bold text-white mb-0"><i class="bi bi-person-plus-fill me-2"
                                                           style="color:#e34c38;"></i>YENİ PERSONEL</h6>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-page-handler="AddBarber">
                        <label class="text-secondary small fw-bold mb-2">BERBER ADI *</label>
                        <input asp-for="NewBarberName" class="dark-input mb-3" placeholder="Örn: Ahmet" required />
                        <label class="text-secondary small fw-bold mb-2">KISA ÖZGEÇMİŞ / UNVAN</label>
                        <textarea asp-for="NewBarberBio" class="dark-textarea mb-3" rows="3"
                                  placeholder="Örn: Usta Makas / Renk Uzmanı"></textarea>
                        <button type="submit" class="btn-sharp-red">+ SİSTEME EKLE</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="admin-card">
                <div class="admin-card-header">
                    <h6 class="fw-bold text-white mb-0"><i class="bi bi-scissors me-2" style="color:#e34c38;"></i>MEVCUT
                        KADRO</h6>
                    </div>
                    <div class="table-responsive">
                        <table class="table dark-table align-middle">
                            <thead>
                                <tr>
                                    <th class="ps-4">Berber</th>
                                    <th>Unvan</th>
                                    <th>Durum</th>
                                    <th class="text-end pe-4">Aksiyon</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Barbers)
                                {
                                    <tr style="@(!item.IsActive ? "opacity:0.35" : "")">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-2 text-white fw-bold">
                                                <div
                                                    style="width:30px; height:30px; background:#222; border-radius:50%; display:flex; align-items:center; justify-content:center; color:#e34c38; font-weight:900;">
                                                    @item.Name.Substring(0,1).ToUpper()</div>
                                                    @item.Name
                                                </div>
                                            </td>
                                            <td class="text-secondary small">@(item.Bio ?? "-")</td>
                                            <td><span class="badge @(item.IsActive ? "bg-success" : "bg-secondary") rounded-pill"
                                                      style="font-size:0.6rem; font-weight:900;">@(item.IsActive ? "AKTİF" :
                                                                                    "PASİF")</span></td>
                                                <td class="text-end pe-4">
                                                    <div class="d-flex justify-content-end gap-2">
                                                        <button class="btn-action-soft"
                                                                onclick="openModal('@item.Id', '@item.Name', 'toggle')">@(item.IsActive ?
                                                                                                    "DURDUR" : "BAŞLAT")</button>
                                                            <button class="btn-action-soft btn-delete"
                                                                    onclick="openModal('@item.Id', '@item.Name', 'delete')"><i
                                                                class="bi bi-trash3"></i></button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>



                        <div id="softetroModal">
                            <div class="modal-box">
                                <i id="mIcon" class="bi fs-1"></i>
                                <h5 id="mTitle" class="text-white fw-bold mt-3"></h5>
                                <p id="mDesc" class="text-secondary small mb-4"></p>
                                <div class="d-flex justify-content-center gap-2">
                                    <button type="button" class="btn-action-soft" onclick="closeModal()">İPTAL</button>
                                    <form id="modalForm" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="barberId" id="mId" />
                                        <button type="submit" id="mBtn" class="btn-action-soft"></button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        @section Scripts {
                            <script>
                                    const modal = document.getElementById('softetroModal');
                                    const form = document.getElementById('modalForm');

                                    function openModal(id, name, type) {
                                        document.getElementById('mId').value = id;
                                        document.getElementById('mTitle').innerText = name;

                                        if (type === 'delete') {
                                            setup('DeleteBarber', 'bi-exclamation-triangle text-danger', 'Bu personelin tüm verileri sistemden KALICI olarak silinecektir.', 'EVET, SİL', 'btn-delete');
                                        } else {
                                            setup('ToggleActive', 'bi-arrow-left-right text-warning', 'Personelin çalışma durumu değiştirilecektir.', 'ONAYLA', '');
                                        }
                                        modal.style.display = 'flex';
                                    }

                                    function setup(h, i, d, b, c) {
                                        form.action = `?handler=${h}`;
                                        document.getElementById('mIcon').className = 'bi ' + i;
                                        document.getElementById('mDesc').innerText = d;
                                        document.getElementById('mBtn').innerText = b;
                                        document.getElementById('mBtn').className = 'btn-action-soft ' + c;
                                    }

                                    function closeModal() { modal.style.display = 'none'; }
                                    window.onclick = (e) => { if (e.target == modal) closeModal(); }
                            </script>
                        }