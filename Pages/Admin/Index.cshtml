@page
@model SoftetroBarber.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<style>
    /* Dashboard Stat Kartları */
    .stat-card {
        border: 1px solid #222;
        border-radius: 6px;
        padding: 25px;
        position: relative;
        overflow: hidden;
        transition: 0.3s;
        background: #1a1a1a;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .stat-icon {
        position: absolute;
        right: 20px;
        bottom: 10px;
        font-size: 3.5rem;
        opacity: 0.15;
        color: #fff;
    }

    /* Softetro Neon Borderlar */
    .stat-primary {
        border-left: 4px solid #3498db;
    }

    .stat-success {
        border-left: 4px solid #2ecc71;
    }

    .stat-info {
        border-left: 4px solid #e34c38;
    }

    /* Softetro Red */
    .stat-warning {
        border-left: 4px solid #f1c40f;
    }

    .stat-label {
        color: #888;
        font-weight: 800;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
    }

    .stat-value {
        color: #fff;
        font-weight: 900;
        font-size: 1.8rem;
    }

    /* Admin Tablo Yapısı */
    .admin-card {
        background-color: #1a1a1a;
        border: 1px solid #222;
        border-radius: 6px;
    }

    .admin-card-header {
        background-color: #111;
        border-bottom: 1px solid #222;
        padding: 20px 25px;
        border-radius: 6px 6px 0 0;
    }

    .dark-table {
        color: #ccc;
        margin-bottom: 0;
    }

    .dark-table thead th {
        background-color: #0a0a0a;
        color: #888;
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.7rem;
        padding: 15px 20px;
    }

    .btn-outline-red {
        border: 1px solid #333;
        color: #888;
        font-weight: 700;
        font-size: 0.8rem;
        padding: 6px 15px;
        border-radius: 4px;
        transition: 0.3s;
        text-decoration: none;
    }

    .btn-outline-red:hover {
        border-color: #e34c38;
        color: #fff;
        background: rgba(227, 76, 56, 0.1);
    }
</style>

<div class="row g-4 mb-5">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-primary">
            <div class="stat-label">Günün Kalan İşleri</div>
            <div class="stat-value">@Model.UpcomingAppointments.Count</div>
            <i class="bi bi-hourglass-split stat-icon"></i>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-success">
            <div class="stat-label d-flex justify-content-between align-items-center">
                <span>Bugünkü Net Kar</span>
                <span class="badge bg-success bg-opacity-25 text-success rounded-pill px-2">Kasa</span>
            </div>
            <div class="stat-value">@Model.TodayNetProfit.ToString("C0")</div>
            <i class="bi bi-cash-stack stat-icon"></i>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-info">
            <div class="stat-label">Ekip Mevcudu</div>
            <div class="stat-value">@Model.TotalBarbersCount</div>
            <i class="bi bi-scissors stat-icon"></i>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card stat-warning">
            <div class="stat-label">Müşteri Portföyü</div>
            <div class="stat-value">@Model.TotalCustomersCount</div>
            <i class="bi bi-people stat-icon"></i>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Grafikler Satırı -->
    <div class="col-lg-8">
        <div class="admin-card h-100">
            <div class="admin-card-header">
                <h5 class="fw-bold text-white mb-0" style="letter-spacing: 1px;">SON 7 GÜNÜN GELİR GRAFİĞİ</h5>
            </div>
            <div class="card-body p-4 w-100">
                <canvas id="revenueChart" style="max-height: 300px; width: 100%;"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="admin-card h-100">
            <div class="admin-card-header">
                <h5 class="fw-bold text-white mb-0" style="letter-spacing: 1px;">EN ÇOK TERCİH EDİLENLER</h5>
            </div>
            <div class="card-body p-4 d-flex justify-content-center align-items-center">
                <canvas id="servicesChart" style="max-height: 250px;"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Popüler Berberler ve Yaklaşan Randevular Satırı -->
    <div class="col-lg-4">
        <div class="admin-card h-100">
            <div class="admin-card-header">
                <h5 class="fw-bold text-white mb-0" style="letter-spacing: 1px;">HAFTANIN YILDIZLARI</h5>
                <small class="text-secondary">En çok randevu tamamlayan 3 berber.</small>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush" style="border-radius: 0 0 6px 6px;">
                    @if (Model.TopBarbers.Any())
                    {
                        for (int i = 0; i < Model.TopBarbers.Count; i++)
                        {
                            var barber = Model.TopBarbers[i];
                            <li class="list-group-item d-flex justify-content-between align-items-center p-4"
                                style="background-color: transparent; border-bottom: 1px solid #222; color: #fff;">
                                <div>
                                    <h6 class="mb-1 fw-bold">
                                        @if (i == 0)
                                        {
                                            <i class="bi bi-trophy-fill text-warning me-2"></i>
                                        }
                                        else if (i == 1)
                                        {

                                            <i class="bi bi-award-fill text-secondary me-2"></i>
                                        }
                                        else
                                        {

                                            <i class="bi bi-award text-primary me-2"></i>
                                        }
                                        @barber.Name
                                    </h6>
                                </div>
                                <span class="badge bg-danger rounded-pill px-3 py-2"
                                      style="background-color: var(--theme-red, #e34c38) !important;">
                                    @barber.CompletedAppointments İşlem
                                </span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-center p-4"
                            style="background-color: transparent; border: none; color: #666;">
                            Veri bulunamadı.
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="admin-card">
            <div class="admin-card-header d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="fw-bold text-white mb-0" style="letter-spacing: 1px;">GÜNÜN KALAN RANDEVULARI</h5>
                    <small class="text-secondary">Şu andan itibaren beklenen tüm operasyonlar.</small>
                </div>
                <a asp-page="/Admin/Appointments" class="btn-outline-red">TÜM AJANDAYI GÖR</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table dark-table align-middle">
                        <thead>
                            <tr>
                                <th class="ps-4">Müşteri Detayı</th>
                                <th>Berber</th>
                                <th>Başlangıç Saati</th>
                                <th>Tahmini Gelir</th>
                                <th class="pe-4 text-end">Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.UpcomingAppointments.Any())
                            {
                                @foreach (var item in Model.UpcomingAppointments)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-bold text-white">@item.Customer.FullName</div>
                                            <div class="small text-muted">@item.Customer.PhoneNumber</div>
                                        </td>
                                        <td class="text-light">
                                            <i class="bi bi-person-badge me-1 opacity-50"></i> @item.Barber.Name
                                        </td>
                                        <td style="color: #fff; font-weight: 700;">
                                            <i class="bi bi-clock me-1 text-info"></i> @item.StartTime.ToString("HH:mm")
                                        </td>
                                        <td style="color: #2ecc71; font-weight: 800;">@item.TotalPrice.ToString("C0")</td>
                                        <td class="pe-4 text-end">
                                            <span class="badge bg-dark border border-info text-info rounded-pill px-3">
                                                Bekleniyor
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <i class="bi bi-calendar-check d-block mb-3 opacity-25"
                                           style="font-size: 3rem;"></i>
                                        <span style="color: #666; font-weight: 700;">Günün geri kalanı için planlanmış
                                            randevu bulunmuyor.</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {

            // --- Gelir & Gider Grafiği (Line Chart) ---
            const revenueLabels = @Html.Raw(Json.Serialize(Model.Last7DaysRevenue.Keys));
            const revenueData = @Html.Raw(Json.Serialize(Model.Last7DaysRevenue.Values));
            const expenseData = @Html.Raw(Json.Serialize(Model.Last7DaysExpense.Values));

            const ctxRevenue = document.getElementById('revenueChart').getContext('2d');
            new Chart(ctxRevenue, {
            type: 'line',
            data: {
            labels: revenueLabels,
            datasets: [
            {
            label: 'Gelir (₺)',
            data: revenueData,
            borderColor: '#2ecc71',
            backgroundColor: 'rgba(46, 204, 113, 0.1)',
            borderWidth: 3,
            pointBackgroundColor: '#2ecc71',
            pointBorderColor: '#fff',
            pointHoverBackgroundColor: '#fff',
            pointHoverBorderColor: '#2ecc71',
            fill: true,
            tension: 0.4
            },
            {
            label: 'Gider (₺)',
            data: expenseData,
            borderColor: '#e34c38',
            backgroundColor: 'rgba(227, 76, 56, 0.1)',
            borderWidth: 3,
            pointBackgroundColor: '#e34c38',
            pointBorderColor: '#fff',
            pointHoverBackgroundColor: '#fff',
            pointHoverBorderColor: '#e34c38',
            fill: true,
            tension: 0.4
            }
            ]
            },
            options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
            legend: {
            display: true,
            labels: { color: '#ccc' }
            }
            },
            scales: {
            y: {
            beginAtZero: true,
            grid: { color: '#222', drawBorder: false },
            ticks: { color: '#888' }
            },
            x: {
            grid: { display: false },
            ticks: { color: '#888' }
            }
            }
            }
            });

            // --- Hizmet Dağılımı Grafiği (Doughnut/Pie Chart) ---
            const serviceLabels = @Html.Raw(Json.Serialize(Model.TopServicesUsage.Keys));
            const serviceData = @Html.Raw(Json.Serialize(Model.TopServicesUsage.Values));

            const ctxServices = document.getElementById('servicesChart').getContext('2d');
            new Chart(ctxServices, {
            type: 'doughnut',
            data: {
            labels: serviceLabels,
            datasets: [{
            data: serviceData,
            backgroundColor: [
            '#e34c38', '#3498db', '#f1c40f', '#2ecc71', '#9b59b6'
            ],
            borderWidth: 0,
            hoverOffset: 4
            }]
            },
            options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
            legend: {
            position: 'bottom',
            labels: { color: '#ccc', padding: 20, font: { size: 11 } }
            }
            },
            cutout: '75%'
            }
            });
            });
        </script>
    }