@page
@model SoftetroBarber.Pages.Admin.ServicesModel
@{
    ViewData["Title"] = "Hizmet Yönetimi";
}

@Html.AntiForgeryToken() @* Güvenlik token'ı: Kaydetme sorunu için kritik! *@

<style>
    /* SOFTETRO PREMIUM - MINIMALIST WHITE UI */
    .admin-card {
        background-color: #1a1a1a;
        border: 1px solid #222;
        border-radius: 8px;
    }

    /* Full Beyaz Kutu Tasarımı */
    .white-box {
        background: #ffffff !important;
        border: none !important;
        border-radius: 4px;
        color: #000 !important;
        font-weight: 800 !important;
        font-size: 1rem !important;
        height: 40px;
        width: 110px;
        text-align: center;
        outline: none !important;
        transition: 0.3s ease;
        appearance: none;
        -webkit-appearance: none;
    }

    /* Select kutusunda okları gizle veya minimal tut */
    select.white-box {
        cursor: pointer;
        padding-right: 5px;
    }

    /* Price TextBox spin oklarını kaldır */
    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    /* Kayıt başarılı olunca yeşil yanma efekti */
    .save-flash {
        box-shadow: 0 0 15px #2ecc71 !important;
        transform: scale(1.05);
    }

    /* Bildirim Kutusu */
    #statusAlert {
        display: none;
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        background: #2ecc71;
        color: #fff;
        padding: 15px 25px;
        border-radius: 4px;
        font-weight: 700;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }
</style>

<div id="statusAlert">
    <i class="bi bi-check-circle-fill me-2"></i> <span id="alertMsg">Başarıyla Kaydedildi!</span>
</div>

<div class="admin-card mt-4">
    <div class="admin-card-header p-4 border-bottom border-secondary">
        <h5 class="text-white fw-900 m-0 text-uppercase">Portfoy Yönetimi</h5>
    </div>

    <div class="table-responsive">
        <table class="table table-dark m-0 align-middle">
            <thead>
                <tr class="text-secondary small" style="background: #0a0a0a;">
                    <th class="ps-4 py-3">HİZMET</th>
                    <th class="text-center">SÜRE</th>
                    <th class="text-end pe-4">FİYAT (₺)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.ServicesList)
                {
                    <tr>
                        <td class="ps-4 fw-bold text-white">@item.Name</td>

                        <td class="text-center">
                            <select class="white-box" onchange="performAutoSave('@item.Id', null, this.value, this)">
                                @for (int i = 15; i <= 120; i += 15)
                                {
                                    <option value="@i" selected="@(item.DurationInMinutes == i)">@i dk</option>
                                }
                            </select>
                        </td>

                        <td class="pe-4">
                            <div class="d-flex justify-content-end">
                                <input type="number" class="white-box" value="@item.Price.ToString("0")"
                                       onfocusout="performAutoSave('@item.Id', this.value, null, this)">
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
            async function performAutoSave(serviceId, price, duration, element) {
                // Anti-forgery token'ı zorunlu!
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                // URL parametrelerini hazırla
                let params = new URLSearchParams();
                params.append('serviceId', serviceId);
                if (price !== null) params.append('price', price);
                if (duration !== null) params.append('duration', duration);

                try {
                    const response = await fetch(`?handler=AutoUpdate&${params.toString()}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token,
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    const result = await response.json();

                    if (result.success) {
                        // Görsel Onay: Kutuyu parlat
                        element.classList.add('save-flash');
                        setTimeout(() => element.classList.remove('save-flash'), 800);

                        // Üstte Bildirim Göster
                        const alertDiv = document.getElementById('statusAlert');
                        document.getElementById('alertMsg').innerText = result.message;
                        alertDiv.style.display = 'block';
                        setTimeout(() => { alertDiv.style.display = 'none'; }, 2500);
                    } else {
                        alert("Hata: " + result.message);
                    }
                } catch (error) {
                    console.error('Bağlantı hatası:', error);
                    alert("Sunucuyla bağlantı kurulamadı!");
                }
            }
    </script>
}