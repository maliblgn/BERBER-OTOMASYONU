@page
@model SoftetroBarber.Pages.Admin.BarberScheduleModel
@{
    ViewData["Title"] = "Çalışma ve Mola Planı";
}

<style>
    /* Admin Paneli Genel Karanlık Tema Stilleri */
    .admin-card {
        background-color: #1a1a1a;
        border: 1px solid #222;
        border-radius: 6px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .admin-card-header {
        background-color: #111;
        border-bottom: 1px solid #222;
        border-radius: 6px 6px 0 0;
        padding: 20px 25px;
    }

    /* Form Giriş Alanları (Inputs) */
    .dark-label {
        color: #888;
        font-weight: 800;
        font-size: 0.75rem;
        letter-spacing: 1px;
        margin-bottom: 8px;
        display: block;
    }

    .dark-input,
    .dark-select {
        background-color: #000;
        border: 1px solid #222;
        color: #fff;
        border-radius: 4px;
        padding: 12px 15px;
        width: 100%;
        outline: none;
        transition: 0.3s;
        color-scheme: dark;
    }

    .dark-input:focus,
    .dark-select:focus {
        border-color: var(--theme-red, #e34c38);
        box-shadow: 0 0 10px rgba(227, 76, 56, 0.1);
    }

    /* Ana İşlem Butonu */
    .btn-sharp-red {
        background: var(--theme-red, #e34c38);
        color: #fff;
        border: none;
        width: 100%;
        height: 50px;
        font-weight: 800;
        letter-spacing: 1px;
        border-radius: 4px;
        transition: 0.3s;
        cursor: pointer;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-sharp-red:hover {
        box-shadow: 0 5px 20px rgba(227, 76, 56, 0.4);
        filter: brightness(1.1);
    }

    /* Karanlık Tablo Yapısı */
    .dark-table {
        color: #ccc;
        margin-bottom: 0;
    }

    .dark-table thead th {
        background-color: #0a0a0a;
        color: #888;
        border-bottom: 2px solid #222;
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
        padding: 15px 20px;
    }

    .dark-table tbody td {
        border-bottom: 1px solid #222;
        padding: 18px 20px;
        vertical-align: middle;
    }

    .time-badge {
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        border: 1px solid #333;
        padding: 5px 12px;
        border-radius: 4px;
        font-size: 0.85rem;
        font-weight: 700;
        display: inline-block;
    }

    .btn-delete-icon {
        background: transparent;
        border: 1px solid #333;
        color: #666;
        padding: 5px 10px;
        border-radius: 4px;
        transition: 0.3s;
    }

    .btn-delete-icon:hover {
        border-color: #e74c3c;
        color: #e74c3c;
        background: rgba(231, 76, 60, 0.05);
    }

    .admin-alert {
        border-radius: 4px;
        font-weight: 700;
        border: none;
        font-size: 0.9rem;
        background: rgba(46, 204, 113, 0.1);
        color: #2ecc71;
        border: 1px solid rgba(46, 204, 113, 0.2);
    }
</style>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert admin-alert alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="admin-card h-100">
            <div class="admin-card-header">
                <h5 class="fw-bold text-white mb-0" style="letter-spacing: 1px;">
                    <i class="bi bi-clock-history me-2" style="color: var(--theme-red, #e34c38);"></i>MOLA / İZİN EKLE
                </h5>
                <p
                    style="color: #555; font-size: 0.7rem; margin-top: 5px; font-weight: 800; text-transform: uppercase;">
                    Müşterilere randevu ekranında bu saatler kapatılır.</p>
                </div>
                <div class="card-body p-4">

                    @if (!ModelState.IsValid)
                    {
                        <div class="alert p-3 mb-4"
                             style="background: rgba(231, 76, 60, 0.1); color: #e74c3c; border: 1px solid #e74c3c; font-size: 0.85rem;">
                            <div asp-validation-summary="All" class="mb-0"></div>
                        </div>
                    }

                    <form method="post">
                        <div class="mb-4">
                            <label class="dark-label">BERBER SEÇİN</label>
                            <select asp-for="SelectedBarberId" class="dark-select" required>
                                <option value="">-- Berber Listesi --</option>
                                @foreach (var barber in Model.Barbers)
                                {
                                    <option value="@barber.Id">@barber.Name</option>
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="dark-label">MOLA TARİHİ</label>
                            <input type="date" asp-for="MolaDate" class="dark-input" required
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-6">
                                <label class="dark-label">BAŞLANGIÇ</label>
                                <input type="time" asp-for="StartTime" class="dark-input" required />
                            </div>
                            <div class="col-6">
                                <label class="dark-label">BİTİŞ</label>
                                <input type="time" asp-for="EndTime" class="dark-input" required />
                            </div>
                        </div>

                        <div class="mb-5">
                            <label class="dark-label">AÇIKLAMA (OPSİYONEL)</label>
                            <input type="text" asp-for="Reason" class="dark-input" placeholder="Örn: Yemek Molası" />
                        </div>

                        <button type="submit" class="btn-sharp-red">
                            <i class="bi bi-calendar-plus me-2"></i> İZİN TANIMLA
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="admin-card h-100">
                <div class="admin-card-header">
                    <h5 class="fw-bold text-white mb-0" style="letter-spacing: 1px;">
                        <i class="bi bi-list-stars me-2" style="color: var(--theme-red, #e34c38);"></i>AKTİF İZİNLER
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table dark-table align-middle">
                            <thead>
                                <tr>
                                    <th class="ps-4">Berber</th>
                                    <th>Tarih</th>
                                    <th>Saat</th>
                                    <th>Sebep</th>
                                    <th class="text-end pe-4">İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentTimeOffs.Any())
                                {
                                    @foreach (var timeOff in Model.RecentTimeOffs)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-white">@timeOff.Barber.Name</td>
                                            <td class="text-light">@timeOff.StartDateTime.ToString("dd MMM yyyy")</td>
                                            <td>
                                                <div class="time-badge">
                                                    @timeOff.StartDateTime.ToString("HH:mm") -
                                                    @timeOff.EndDateTime.ToString("HH:mm")
                                                </div>
                                            </td>
                                            <td style="color: #666; font-size: 0.85rem;">@(string.IsNullOrEmpty(timeOff.Reason) ?
                                                                                    "Belirtilmedi" : timeOff.Reason)</td>
                                                <td class="text-end pe-4">
                                                    <form method="post" asp-page-handler="Delete"
                                                          onsubmit="return confirm('Bu izni silmek istediğinize emin misiniz?');">
                                                        <input type="hidden" name="timeOffId" value="@timeOff.Id" />
                                                        <button type="submit" class="btn-delete-icon">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    }
                            else
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center py-5">
                                                <span
                                                    style="color: #444; font-weight: 800; text-transform: uppercase; font-size: 0.75rem;">Henüz
                                                    bir mola tanımlanmadı.</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>