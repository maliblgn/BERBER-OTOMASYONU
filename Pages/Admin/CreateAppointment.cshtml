@page
@model SoftetroBarber.Pages.Admin.CreateAppointmentModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Hızlı Randevu Kaydı";
}

<style>
    /* SOFTETRO PREMIUM MANUEL AKIŞ UI */
    body { background-color: #0c0c0c; color: #fff; }
    .page-container { max-width: 650px; margin: 0 auto; padding: 20px 15px; }

    /* Navigasyon Butonu (Geri Tuşu) */
    .btn-back {
        display: inline-flex; align-items: center; gap: 8px;
        color: #888; text-decoration: none; font-weight: 800; font-size: 0.75rem;
        padding: 8px 15px; border: 1px solid #222; border-radius: 50px;
        transition: 0.3s; margin-bottom: 20px;
    }
    .btn-back:hover { color: #fff; border-color: #e34c38; background: rgba(227, 76, 56, 0.05); }

    /* Kutucuk Tasarımları */
    .selection-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 10px; margin-bottom: 20px; }
    .box-option {
        background: #111; border: 1px solid #222; border-radius: 12px; padding: 10px; text-align: center;
        cursor: pointer; transition: 0.2s; color: #555; font-weight: 800; font-size: 0.75rem;
    }
    .box-option.active { border-color: #e34c38; color: #fff; background: rgba(227, 76, 56, 0.1); }

    /* Tarih Seçici */
    .date-box {
        background: #111; border: 1px solid #e34c38; border-radius: 50px;
        padding: 5px 15px; display: inline-flex; align-items: center; gap: 8px; margin-bottom: 25px;
    }
    .date-input-custom { background: transparent; border: none; color: #e34c38; font-weight: 900; font-size: 1rem; outline: none; cursor: pointer; }

    /* Saat Slotları */
    .time-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 6px; margin-bottom: 25px; }
    .time-slot {
        background: #111; border: 1px solid #222; border-radius: 6px; padding: 12px;
        text-align: center; font-weight: 900; font-size: 0.8rem; color: #fff; cursor: pointer; position: relative;
    }
    .time-slot.booked { opacity: 0.15; cursor: not-allowed; text-decoration: line-through; }
    .time-slot.selected { background: #fff; color: #000; border-color: #fff; transform: scale(1.05); }

    /* Giriş Alanları */
    .premium-input { background: #111; border: 1px solid #222; border-radius: 10px; padding: 12px; color: #fff; font-weight: 700; width: 100%; margin-bottom: 12px; outline: none; }

    /* Fiyat Alanına Özel Tasarım */
    .price-wrapper { position: relative; display: flex; align-items: center; }
    .price-symbol { position: absolute; left: 15px; color: #e34c38; font-weight: 900; font-size: 1.1rem; pointer-events: none; }
    .premium-input-price {
        background: #111; border: 1px solid #222; border-radius: 10px; padding: 12px 15px 12px 40px;
        color: #fff; font-weight: 700; width: 100%; outline: none; transition: 0.3s;
        border-left: 4px solid #e34c38 !important;
    }
</style>

<div class="page-container text-center">
    <div class="text-start">
        <a asp-page="/Admin/Appointments" class="btn-back">
            <i class="bi bi-arrow-left"></i> AJANDAYA DÖN
        </a>
    </div>

    <form method="post" id="mainForm">
        <h6 class="text-secondary small fw-bold mb-2">1. PERSONEL SEÇİNİZ</h6>
        <div class="selection-grid">
            @foreach (var barber in Model.ActiveBarbers)
            {
                <div class="box-option @(Model.SelectedBarberId == barber.Id ? "active" : "")"
                     onclick="updateBarber('@barber.Id')">@barber.Name.ToUpper()</div>
            }
            <input type="hidden" asp-for="SelectedBarberId" id="hidBarber" />
        </div>

        <div class="date-box">
            <input type="date" asp-for="AppointmentDate" id="datePicker" 
                   min="@DateTime.Today.ToString("yyyy-MM-dd")"
                   class="date-input-custom" onchange="refreshAll()" />
            <i class="bi bi-calendar3 text-secondary"></i>
        </div>

        <h6 class="text-secondary small fw-bold mb-2">2. İŞLEM SÜRESİ</h6>
        <div class="selection-grid">
            @foreach (var min in new[] { 15, 30, 45, 60, 90 })
            {
                <div class="box-option @(Model.Duration == min ? "active" : "")" onclick="updateDuration(@min)">@min DK</div>
            }
            <input type="hidden" asp-for="Duration" id="hidDuration" />
        </div>

        <h6 class="text-secondary small fw-bold mb-2">3. UYGUN SAATLER</h6>
        <div class="time-grid">
            @foreach (var slot in Model.TimeSlots)
            {
                <div class="time-slot @(slot.IsBooked ? "booked" : "")"
                     onclick="@(slot.IsBooked ? "" : $"selectTime('{slot.Time}', this)")">
                    @slot.Time.ToString(@"hh\:mm")
                    @if(slot.IsBooked) { <div style="font-size:0.5rem; color:#ff4d4d; position:absolute; bottom:2px; left:0; right:0;">DOLU</div> }
                </div>
            }
            <input type="hidden" asp-for="AppointmentTime" id="hidTime" />
        </div>

        <div class="text-start" style="background: #111; padding: 20px; border-radius: 15px; border: 1px solid #222;">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="text-secondary small fw-bold mb-1">TELEFON NUMARASI *</label>
                    <input type="text" asp-for="CustomerPhone" class="premium-input" placeholder="05XX XXX XX XX" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="text-secondary small fw-bold mb-1">FİYAT (OPSİYONEL)</label>
                    <div class="price-wrapper">
                        <span class="price-symbol">₺</span>
                        <input type="text" asp-for="TotalPrice" class="premium-input-price" placeholder="0" />
                    </div>
                </div>
            </div>
            <label class="text-secondary small fw-bold mb-1">MÜŞTERİ AD SOYAD (OPSİYONEL)</label>
            <input type="text" asp-for="CustomerName" class="premium-input" placeholder="Yazılmasa da olur..." />
        </div>

        <button type="submit" class="btn btn-danger w-100 py-3 mt-4 fw-bold shadow-lg" style="border-radius: 12px; font-size: 1rem;">
            RANDEVUYU SİSTEME İŞLE
        </button>
    </form>
</div>

@section Scripts {
    <script>
        function updateBarber(id) { document.getElementById('hidBarber').value = id; refreshAll(); }
        function updateDuration(val) { document.getElementById('hidDuration').value = val; refreshAll(); }
        function selectTime(time, el) {
            if (el.classList.contains('booked')) return;
            document.querySelectorAll('.time-slot').forEach(s => s.classList.remove('selected'));
            el.classList.add('selected');
            document.getElementById('hidTime').value = time;
        }
        function refreshAll() {
            const date = document.getElementById('datePicker').value;
            const dur = document.getElementById('hidDuration').value;
            const barb = document.getElementById('hidBarber').value;
            window.location.href = `?date=${date}&duration=${dur}&barberId=${barb}`;
        }
    </script>
}