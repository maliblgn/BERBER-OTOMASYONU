<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Elit Makas Berber</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SoftetroBarber.styles.css" asp-append-version="true" />

    <style>
            /* Sadece Navbar için çok küçük ayarlamalar */
            .navbar-brand-text {
                font-weight: 900;
                letter-spacing: 1px;
                font-size: 1.5rem;
                color: #fff;
            }
            .custom-navbar {
                border-bottom: 1px solid rgba(255, 255, 255, 0.05);
                padding: 1rem 0;
                background-color: #050505;
            }
    </style>
</head>

<body style="background-color: #050505;">

    <header>
        <nav class="navbar navbar-expand-lg custom-navbar">
            <div class="container d-flex justify-content-between align-items-center">
                <a class="navbar-brand d-flex align-items-center" asp-page="/Index">
                    <i class="bi bi-scissors fs-3 me-2" style="color: #f04e3b;"></i>
                    <span class="navbar-brand-text">ELİT MAKAS <span style="color: #f04e3b;">BERBER</span></span>
                </a>
                <a href="/Admin/Index" class="btn text-white"
                       style="background-color: #f04e3b; border-radius: 2px; padding: 10px 20px; font-weight: 800; font-size: 0.8rem; text-transform: uppercase; transition: 0.3s;"
                       onmouseover="this.style.filter='brightness(1.2)'" onmouseout="this.style.filter='brightness(1)'">
                    <i class="bi bi-person-lock me-1"></i> BERBER GİRİŞ
                </a>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>