<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Elit Makas Berber</title>

    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800;900&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SoftetroBarber.styles.css" asp-append-version="true" />

    <style>
                                                                    /* Global Font ve Arka Plan */
                                                                    body {
                                                                        background-color: #000000 !important;
                                                                        /* Pure Black */
                                                                        font-family: 'Montserrat', sans-serif !important;
                                                                        color: #ffffff;
                                                                    }

                                                                    /* Navigasyon Alanı */
                                                                    .custom-navbar {
                                                                        padding: 1.2rem 0;
                                                                        background-color: #000000;
                                                                    }

                                                                    /* ELİT MAKAS BERBER - Tam Kırmızı Tasarım */
                                                                    .brand-red-full {
                                                                        font-weight: 900;
                                                                        letter-spacing: 0.5px;
                                                                        font-size: 1.4rem;
                                                                        color: #e34c38 !important;
                                                                        /* Softetro Kırmızısı */
                                                                        text-transform: uppercase;
                                                                        text-decoration: none;
                                                                        display: flex;
                                                                        align-items: center;
                                                                        gap: 12px;
                                                                    }

                                                                    /* Üst Bar Altındaki İnce Çizgi */
                                                                    .header-line {
                                                                        border-bottom: 1px solid rgb(186, 186, 186);
                                                                        width: 100%;
                                                                    }

                                                                    /* Berber Giriş Butonu - Keskin ve Profesyonel */
                                                                    .btn-admin-entry {
                                                                        background-color: #e34c38;
                                                                        color: #fff !important;
                                                                        border-radius: 4px;
                                                                        padding: 10px 24px;
                                                                        font-weight: 800;
                                                                        font-size: 0.75rem;
                                                                        text-transform: uppercase;
                                                                        transition: 0.3s;
                                                                        border: none;
                                                                    }

                                                                    .btn-admin-entry:hover {
                                                                        box-shadow: 0 10px 25px rgba(227, 76, 56, 0.4);
            transform: translateY(-2px);
                                                                    }
    </style>
</head>

<body>

    <header>
        <nav class="navbar custom-navbar">
            <div class="container d-flex justify-content-between align-items-center">
                <a class="brand-red-full" asp-page="/Index" style="text-decoration: none;">
                    ELİT <span style="color: #ffffff;">MAKAS </span> Berber
                </a>
                <a href="/Admin/Index" class="btn-admin-entry">
                    <i class="bi bi-person-fill-lock me-2"></i> BERBER GİRİŞİ
                </a>
            </div>
        </nav>
        <div class="header-line"></div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="mt-auto py-4">
        <div class="container text-center">
            <p
                style="color: #333; font-size: 0.7rem; letter-spacing: 2px; font-weight: 800; text-transform: uppercase;  solid #111; pt-4">
                SOFTETRO STUDİO RANDEVU SİSTEMİ
            </p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>