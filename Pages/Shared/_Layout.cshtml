<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Elit Makas Berber</title>
    
    <!-- Bootstrap 5 CSS CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SoftetroBarber.styles.css" asp-append-version="true" />
    <style>
        .page-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-image: url('/images/bg.jpg');
            background-size: cover;
            background-position: center;
            z-index: -2;
        }

        .page-bg-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-color: var(--bg-black-transparent);
            z-index: -1;
        }

        .navbar-brand-text {
            font-weight: 900;
            letter-spacing: 1px;
            font-size: 1.5rem;
            color: var(--text-white);
        }

        .navbar-brand-text span {
            color: var(--theme-red);
        }

        .custom-navbar {
            background-color: transparent !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 1rem;
            padding-bottom: 1rem;
        }

        .btn-berber-giris {
            background-color: var(--theme-red);
            color: var(--text-white);
            border-radius: 8px;
            padding: 8px 24px;
            font-weight: bold;
            font-size: 0.95rem;
            transition: all 0.3s;
        }

        .btn-berber-giris:hover {
            background-color: var(--theme-red-hover);
            color: white;
        }

        .step-indicator {
            display: flex;
            justify-content: space-between;
            margin-bottom: 2rem;
            position: relative;
        }
        .step-indicator::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 2px;
            background-color: rgba(255,255,255,0.1);
            z-index: 1;
        }
        .step-item {
            position: relative;
            z-index: 2;
            padding: 0 10px;
            text-align: center;
            background: transparent;
        }
        .step-circle {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: var(--dark-card-solid);
            border: 2px solid rgba(255,255,255,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            margin: 0 auto;
            color: var(--text-muted-dark);
            transition: 0.3s;
        }
        .step-item.active .step-circle {
            background-color: var(--accent);
            border-color: var(--accent);
            color: #fff;
            box-shadow: 0 0 15px rgba(231,76,60,0.4);
        }
        .step-item.completed .step-circle {
            background-color: #27ae60;
            border-color: #27ae60;
            color: #fff;
        }
        .step-title {
            font-size: 0.8rem;
            margin-top: 8px;
            color: var(--text-muted-dark);
        }
        .step-item.active .step-title {
            color: var(--accent);
            font-weight: bold;
        }
        .step-item.completed .step-title {
            color: #27ae60;
        }

        .booking-card {
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 12px;
            background: rgba(40,40,40,0.5);
            backdrop-filter: blur(10px);
            transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
        }
        .booking-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.5);
            border-color: rgba(255,255,255,0.1);
        }
        .booking-card.selected {
            border: 2px solid var(--accent);
            background-color: rgba(231,76,60,0.05);
        }
    </style>
</head>
<body>
    <div class="page-bg"></div>
    <div class="page-bg-overlay"></div>

    <header>
        <nav class="navbar navbar-expand-lg custom-navbar mb-5">
            <div class="container d-flex justify-content-between align-items-center">
                <a class="navbar-brand text-decoration-none d-flex align-items-center" asp-area="" asp-page="/Index">
                    <i class="bi bi-scissors fs-3 me-2" style="color: var(--theme-red);"></i>
                    <span class="navbar-brand-text">ELİT MAKAS <span>BERBER</span></span>
                </a>
                
                <a href="/Admin/Index" class="btn btn-berber-giris text-decoration-none">
                    BERBER GİRİŞ
                </a>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <!-- Removed sticky footer as per the mockup style which has a cleaner look, the mockup footer is inside the card instead. -->

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
