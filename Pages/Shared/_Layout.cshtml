<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Elit Makas Berber</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SoftetroBarber.styles.css" asp-append-version="true" />

    <style>
                .page-bg {
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100vw;
                    height: 100vh;
                    background-image: url('/images/barber-bg.png');
                    /* Klasördeki isimle eşleşmeli */
                    background-size: cover;
                    background-position: center;
                    z-index: -2;
                }
                .page-bg-overlay {
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100vw;
                    height: 100vh;
                    background-color: var(--bg-black-transparent);
                    z-index: -1;
                }
                .navbar-brand-text {
                    font-weight: 900;
                    letter-spacing: 1px;
                    font-size: 1.5rem;
                    color: #fff;
                }
                .navbar-brand-text span {
                    color: var(--theme-red);
                }
                .custom-navbar {
                    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
                    padding: 1rem 0;
                }
                .btn-berber-giris {
    background-color: var(--theme-red) !important;
    color: #ffffff !important; /* Yazıyı net beyaz yaptık */
    border-radius: 8px;
    padding: 10px 24px;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    transition: all 0.3s ease-in-out;
    border: none;
    display: inline-flex;
    align-items: center;
    box-shadow: 0 4px 15px rgba(231, 76, 60, 0.2);
}

.btn-berber-giris:hover {
    background-color: var(--theme-red-hover) !important;
    color: #ffffff !important;
    transform: translateY(-2px); /* Hafif yukarı zıplama efekti */
    box-shadow: 0 6px 20px rgba(231, 76, 60, 0.4);
}
    </style>
</head>

<body>
    <div class="page-bg"></div>
    <div class="page-bg-overlay"></div>

    <header>
        <nav class="navbar navbar-expand-lg custom-navbar mb-4">
            <div class="container d-flex justify-content-between align-items-center">
                <a class="navbar-brand d-flex align-items-center" asp-page="/Index">
                    <i class="bi bi-scissors fs-3 me-2" style="color: var(--theme-red);"></i>
                    <span class="navbar-brand-text">ELİT MAKAS <span>BERBER</span></span>
                </a>
                <a href="/Admin/Index" class="btn btn-berber-giris">
                    <i class="bi bi-person-lock me-1"></i> BERBER GİRİŞ
                </a>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>