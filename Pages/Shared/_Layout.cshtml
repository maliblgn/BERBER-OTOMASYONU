<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Elit Makas Berber</title>

    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
                body {
                    background-color: #000000 !important;
                    font-family: 'Montserrat', sans-serif !important;
                    color: #ffffff;
                    margin: 0;
                    padding: 0;
                }

                .custom-navbar {
                    padding: 1rem 0;
                    background-color: #000000;
                }

                /* Logo Ayarları */
                .brand-red-full {
                    font-weight: 900;
                    letter-spacing: -0.5px;
                    font-size: 1.25rem;
                    color: #e34c38 !important;
                    text-transform: uppercase;
                    text-decoration: none;
                    display: flex;
                    align-items: center;
                    gap: 8px;
                    white-space: nowrap;
                }

                .header-line {
                    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
                    width: 100%;
                }

                /* Buton: Mobilde İkon, Masaüstünde Yazılı */
                .btn-admin-entry {
                    background-color: #e34c38;
                    color: #fff !important;
                    border-radius: 6px;
                    padding: 10px 16px;
                    font-weight: 800;
                    font-size: 0.75rem;
                    text-transform: uppercase;
                    transition: 0.3s;
                    border: none;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    text-decoration: none;
                }

                .btn-admin-entry:hover {
                    box-shadow: 0 5px 15px rgba(227, 76, 56, 0.4);
                    transform: translateY(-2px);
                }

                /* MOBİL DOKUNUŞLAR */
                @@media (max-width: 576px) {
                    .custom-navbar .container {
                        padding-left: 15px;
                        padding-right: 15px;
                    }

                    .brand-red-full {
                        font-size: 1rem;
                        /* Mobilde logoyu biraz küçülttük */
                    }

                    .btn-admin-entry {
                        padding: 10px 12px;
                        /* Karemsi bir ikon butona çevirdik */
                    }

                    .btn-text {
                        display: none;
                        /* Mobilde yazıyı gizle */
                    }

                    .btn-admin-entry i {
                        margin: 0 !important;
                        font-size: 1.1rem;
                        /* İkonu mobilde biraz büyüttük */
                    }
                }
    </style>
</head>

<body>
    <header>
        <nav class="navbar custom-navbar">
            <div class="container d-flex justify-content-between align-items-center">
                <a class="brand-red-full" asp-page="/Index" style="text-decoration: none;">
                    ELİT <span class="brand-white">MAKAS</span> <span class="brand-red-text">BERBER</span>
                </a>

                <a href="/Admin/Index" class="btn-admin-entry">
                    <i class="bi bi-person-fill-lock me-md-2"></i>
                    <span class="btn-text">BERBER GİRİŞİ</span>
                </a>
            </div>
        </nav>
        <div class="header-line"></div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="mt-auto py-5">
        <div class="container text-center">
            <p
                style="color: #222; font-size: 0.65rem; letter-spacing: 3px; font-weight: 800; text-transform: uppercase; border-top: 1px solid #111; pt-4; padding-top: 20px;">
                SOFTETRO STUDİO RANDEVU SİSTEMİ
            </p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>