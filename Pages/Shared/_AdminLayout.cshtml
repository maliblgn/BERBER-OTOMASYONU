<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Paneli</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
                #sidebar {
                    min-width: 250px;
                    max-width: 250px;
                    min-height: 100vh;
                    background-color: var(--dark-card-solid);
                    border-right: 1px solid rgba(255, 255, 255, 0.05);
                }

                #sidebar .nav-link {
                    color: var(--text-muted-dark);
                    padding: 12px 20px;
                    border-radius: 8px;
                    margin: 4px 10px;
                    transition: 0.3s;
                }
                #sidebar .nav-link:hover {
                    background: rgba(255, 255, 255, 0.05);
                    color: #fff;
                }

                #sidebar .nav-link.active {
                    background: var(--theme-red);
                    color: #fff;
                    box-shadow: 0 4px 12px rgba(231, 76, 60, 0.3);
                }

                .content-wrapper {
                    flex: 1;
                    padding: 25px;
                    background: var(--bg-black);
                }

                .admin-nav {
                    background: var(--dark-card-solid);
                    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
                    padding: 15px;
                }
    </style>
</head>

<body>
    <div class="d-flex">
        <nav id="sidebar" class="d-none d-md-block">
            <div class="p-4 text-center border-bottom border-secondary mb-3">
                <i class="bi bi-scissors fs-1 text-danger"></i>
                <h5 class="mt-2 fw-bold text-white">Makas Admin</h5>
            </div>
            <ul class="nav flex-column">
                <li class="nav-item"><a
                    class="nav-link @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/Index" ? "active" : "")"
                    asp-page="/Admin/Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                    <li class="nav-item"><a
                        class="nav-link @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/Appointments" ? "active" : "")"
                        asp-page="/Admin/Appointments"><i class="bi bi-calendar-check me-2"></i> Randevular</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Admin/Barbers"><i
                            class="bi bi-person-badge me-2"></i> Berberler</a></li>
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Services"><i class="bi bi-tags me-2"></i>
                                Hizmetler</a></li>
                            </ul>
                        </nav>

                        <div class="content-wrapper">
                            <nav class="admin-nav rounded d-flex justify-content-between align-items-center mb-4">
                                <span class="fw-bold text-white fs-5">@ViewData["Title"]</span>
                                <div>
                                    <span class="text-white me-3"><i class="bi bi-person-circle text-danger me-1"></i>
                                        @User.Identity?.Name</span>
                                        <a asp-page="/Index" class="btn btn-sm btn-outline-light">Siteye Dön</a>
                                    </div>
                                </nav>
                                <main>@RenderBody()</main>
                            </div>
                        </div>

                        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
                        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
                        @await RenderSectionAsync("Scripts", required: false)
                    </body>

                </html>